<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Analytics - <%= @restaurant.name %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
</head>
<body class="min-h-screen bg-gray-50">
  <div class="max-w-5xl mx-auto p-4 md:p-6 space-y-4">

    <!-- Header -->
    <div class="flex items-center justify-between">
      <div>
        <a href="<%= dashboard_path %>" class="text-gray-400 hover:text-gray-600 text-sm flex items-center gap-1 mb-1">
          <i data-lucide="arrow-left" class="w-4 h-4"></i> Dashboard
        </a>
        <h1 class="text-xl font-bold text-gray-900"><%= @restaurant.name %></h1>
        <p class="text-xs text-gray-500"><%= @restaurant.platform_name %></p>
      </div>
      <div class="bg-gray-100 rounded-lg p-0.5 inline-flex">
        <% %w[24h 7d 30d].each do |p| %>
          <button onclick="loadPeriod('<%= p %>')" id="btn-<%= p %>"
            class="period-btn px-3 py-1 text-xs font-medium rounded-md transition-colors <%= p == @period ? 'bg-white text-gray-900 shadow-sm' : 'text-gray-500' %>">
            <%= p %>
          </button>
        <% end %>
      </div>
    </div>

    <!-- Metric Cards -->
    <div class="grid grid-cols-4 gap-3" id="metrics">
      <div class="bg-white rounded-xl border p-4">
        <div class="text-xs text-gray-400 mb-1">Uptime</div>
        <div class="text-2xl font-bold" id="m-uptime">--%</div>
      </div>
      <div class="bg-white rounded-xl border p-4">
        <div class="text-xs text-gray-400 mb-1">Closed</div>
        <div class="text-2xl font-bold" id="m-closed">--</div>
      </div>
      <div class="bg-white rounded-xl border p-4">
        <div class="text-xs text-gray-400 mb-1">Anomalies</div>
        <div class="text-2xl font-bold" id="m-anomalies">0</div>
      </div>
      <div class="bg-white rounded-xl border p-4">
        <div class="text-xs text-gray-400 mb-1">Menu</div>
        <div class="text-2xl font-bold" id="m-menu">--</div>
      </div>
    </div>

    <!-- Status Timeline Heatmap -->
    <div class="bg-white rounded-xl border p-5">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-sm font-semibold text-gray-900">Status Timeline</h3>
        <div class="flex items-center gap-3 text-[10px] text-gray-400">
          <span class="flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-sm bg-green-500"></span>Open</span>
          <span class="flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-sm bg-red-400"></span>Closed</span>
          <span class="flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-sm bg-gray-200"></span>No data</span>
          <span class="flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-sm bg-yellow-400"></span>Anomaly</span>
        </div>
      </div>
      <div id="heatmap">
        <div class="text-center text-sm text-gray-300 py-12">Loading...</div>
      </div>
    </div>

    <!-- Downtime Episodes -->
    <div class="bg-white rounded-xl border p-5">
      <h3 class="text-sm font-semibold text-gray-900 mb-3">Downtime Episodes</h3>
      <div id="episodes"></div>
    </div>

    <!-- Menu Availability -->
    <div class="bg-white rounded-xl border p-5">
      <h3 class="text-sm font-semibold text-gray-900 mb-3">Menu Availability</h3>
      <div id="menu-items">
        <div class="text-sm text-gray-300 py-4 text-center">Loading...</div>
      </div>
    </div>
  </div>

<script>
lucide.createIcons();
const RID = <%= @restaurant.id %>;
let currentPeriod = '<%= @period %>';
const BALI_OFFSET = 8; // UTC+8

function loadPeriod(p) {
  currentPeriod = p;
  document.querySelectorAll('.period-btn').forEach(b => {
    b.classList.remove('bg-white','text-gray-900','shadow-sm');
    b.classList.add('text-gray-500');
  });
  const btn = document.getElementById('btn-'+p);
  btn.classList.add('bg-white','text-gray-900','shadow-sm');
  btn.classList.remove('text-gray-500');
  loadData();
}

async function loadData() {
  const resp = await fetch(`/restaurants/${RID}/analytics_data?period=${currentPeriod}`);
  const data = await resp.json();
  if (!data.success) return;

  const m = data.metrics;
  const uptimePct = m.uptime_percentage.toFixed(1);
  document.getElementById('m-uptime').textContent = uptimePct + '%';
  document.getElementById('m-uptime').className = 'text-2xl font-bold ' +
    (uptimePct >= 95 ? 'text-green-600' : uptimePct >= 70 ? 'text-yellow-600' : 'text-red-600');

  const closedMin = m.closed_checks * 5;
  const cH = Math.floor(closedMin/60), cM = closedMin%60;
  document.getElementById('m-closed').textContent = closedMin === 0 ? '0' : (cH > 0 ? cH+'h '+cM+'m' : cM+'m');
  document.getElementById('m-closed').className = 'text-2xl font-bold ' + (closedMin > 0 ? 'text-red-600' : 'text-green-600');

  document.getElementById('m-anomalies').textContent = m.anomalies_count;
  document.getElementById('m-anomalies').className = 'text-2xl font-bold ' + (m.anomalies_count > 0 ? 'text-yellow-600' : 'text-gray-400');

  buildHeatmap(data.timeline);
  buildEpisodes(data.timeline);
  loadMenuItems();
}

function toBali(ts) {
  return new Date(ts + BALI_OFFSET * 3600000);
}

function buildHeatmap(timeline) {
  const el = document.getElementById('heatmap');
  if (!timeline?.length) { el.innerHTML = '<div class="text-center text-sm text-gray-300 py-8">No data</div>'; return; }

  // Group by day (Bali time)
  const days = {};
  timeline.forEach(t => {
    const d = toBali(t.ts);
    const key = d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
    if (!days[key]) days[key] = [];
    days[key].push({ ...t, baliDate: d });
  });

  const sortedDays = Object.keys(days).sort();
  const cellsPerDay = 24 * 12; // 5-min slots = 288 per day
  const cellW = 100 / cellsPerDay;

  let html = '';

  // Hour markers
  html += '<div class="flex items-center mb-0.5">';
  html += '<div class="w-20 flex-shrink-0"></div>';
  html += '<div class="flex-1 relative h-3">';
  for (let h = 0; h < 24; h += 3) {
    const left = (h / 24 * 100);
    html += `<span class="absolute text-[9px] text-gray-300" style="left:${left}%">${String(h).padStart(2,'0')}</span>`;
  }
  html += '</div></div>';

  sortedDays.forEach(dayKey => {
    const checks = days[dayKey];
    const parts = dayKey.split('-');
    const dateObj = new Date(parts[0], parts[1]-1, parts[2]);
    const label = dateObj.toLocaleDateString('en', { weekday: 'short', day: 'numeric' });
    const todayKey = (() => { const n = toBali(Date.now()); return n.getFullYear()+'-'+String(n.getMonth()+1).padStart(2,'0')+'-'+String(n.getDate()).padStart(2,'0'); })();
    const isToday = dayKey === todayKey;

    // Build 288-slot array
    const slots = new Array(cellsPerDay).fill(null); // null = no data
    checks.forEach(c => {
      const d = c.baliDate;
      const slot = d.getHours() * 12 + Math.floor(d.getMinutes() / 5);
      if (slot >= 0 && slot < cellsPerDay) {
        slots[slot] = { s: c.s, a: c.a };
      }
    });

    // Render day row
    html += '<div class="flex items-center mb-px">';
    html += `<div class="w-20 flex-shrink-0 text-[11px] pr-2 text-right ${isToday ? 'font-bold text-gray-900' : 'text-gray-400'}">${label}</div>`;
    html += '<div class="flex-1 flex h-4 rounded-sm overflow-hidden">';

    // Group consecutive same-status slots for fewer DOM elements
    let i = 0;
    while (i < cellsPerDay) {
      const slot = slots[i];
      let count = 1;
      while (i + count < cellsPerDay) {
        const next = slots[i + count];
        if (slot === null && next === null) { count++; continue; }
        if (slot !== null && next !== null && slot.s === next.s && slot.a === next.a) { count++; continue; }
        break;
      }

      const width = (count * cellW).toFixed(3);
      let cls, title;
      if (slot === null) {
        cls = 'bg-gray-100';
        title = 'No data';
      } else if (slot.a) {
        cls = 'bg-yellow-400';
        title = 'Anomaly';
      } else if (slot.s === 1) {
        cls = 'bg-green-500';
        title = 'Open';
      } else if (slot.s === 0) {
        cls = 'bg-red-400';
        title = 'Closed';
      } else {
        cls = 'bg-gray-300';
        title = 'Error';
      }

      html += `<div class="${cls}" style="width:${width}%" title="${title}"></div>`;
      i += count;
    }

    html += '</div></div>';
  });

  el.innerHTML = html;
}

function buildEpisodes(timeline) {
  const el = document.getElementById('episodes');
  if (!timeline?.length) { el.innerHTML = ''; return; }

  // Find closed/error episodes from raw data
  const episodes = [];
  let cur = null;
  timeline.forEach(t => {
    const bad = t.s <= 0; // closed or error
    if (bad) {
      if (!cur) cur = { start: t, end: t, count: 1, hasAnomaly: !!t.a, isClosed: t.s === 0 };
      else { cur.end = t; cur.count++; if (t.a) cur.hasAnomaly = true; if (t.s === 0) cur.isClosed = true; }
    } else {
      if (cur) { episodes.push(cur); cur = null; }
    }
  });
  if (cur) episodes.push(cur);

  // Only show episodes where restaurant was actually CLOSED (not just errors)
  const closedEpisodes = episodes.filter(e => e.isClosed);

  if (closedEpisodes.length === 0) {
    el.innerHTML = '<div class="text-sm text-green-600 flex items-center gap-1.5 py-1"><i data-lucide="check-circle" class="w-4 h-4"></i>No downtime in this period</div>';
    lucide.createIcons();
    return;
  }

  closedEpisodes.sort((a,b) => b.count - a.count);
  let html = '<div class="space-y-1.5">';
  closedEpisodes.slice(0,15).forEach(ep => {
    const start = toBali(ep.start.ts);
    const end = toBali(ep.end.ts);
    const mins = ep.count * 5;
    const h = Math.floor(mins/60), m = mins%60;
    const dur = h > 0 ? h+'h '+m+'m' : m+'m';
    const day = start.toLocaleDateString('en',{month:'short',day:'numeric'});
    const t1 = start.toLocaleTimeString('en',{hour:'2-digit',minute:'2-digit',hour12:false});
    const t2 = end.toLocaleTimeString('en',{hour:'2-digit',minute:'2-digit',hour12:false});
    const anom = ep.hasAnomaly;

    html += `<div class="flex items-center gap-3 py-1.5 px-3 rounded ${anom ? 'bg-yellow-50' : 'bg-gray-50'}">`;
    html += `<div class="w-1.5 h-1.5 rounded-full bg-red-500 flex-shrink-0"></div>`;
    html += `<span class="text-sm text-gray-700 flex-1">${day} ${t1} - ${t2}`;
    if (anom) html += ' <span class="text-[10px] text-yellow-600 font-semibold">ANOMALY</span>';
    html += `</span>`;
    html += `<span class="text-sm font-mono font-semibold text-red-600">${dur}</span>`;
    html += '</div>';
  });
  html += '</div>';
  el.innerHTML = html;
  lucide.createIcons();
}

async function loadMenuItems() {
  const el = document.getElementById('menu-items');
  try {
    const resp = await fetch(`/restaurants/${RID}.json`);
    if (!resp.ok) { el.innerHTML = '<div class="text-xs text-gray-300">Menu tracking available for GoFood</div>'; return; }
    const data = await resp.json();
    const items = data.menu_items || [];
    const oos = items.filter(i => i.current_status === 0);

    document.getElementById('m-menu').textContent = (items.length - oos.length) + '/' + items.length;
    document.getElementById('m-menu').className = 'text-2xl font-bold ' + (oos.length > 0 ? 'text-orange-600' : 'text-green-600');

    if (!items.length) { el.innerHTML = '<div class="text-xs text-gray-300">No menu data yet</div>'; return; }
    if (!oos.length) { el.innerHTML = '<div class="text-sm text-green-600">All ' + items.length + ' items available</div>'; return; }

    let html = '<div class="grid grid-cols-1 sm:grid-cols-2 gap-1.5">';
    oos.forEach(it => {
      const since = it.status_changed_at ? new Date(it.status_changed_at) : null;
      let dur = '';
      if (since) {
        const ms = Date.now() - since.getTime();
        const h = Math.floor(ms/3600000), d = Math.floor(h/24);
        dur = d > 0 ? d+'d '+(h%24)+'h' : h+'h '+Math.floor((ms%3600000)/60000)+'m';
      }
      html += `<div class="flex items-center gap-2 px-2.5 py-1.5 rounded bg-red-50 text-sm">`;
      html += `<div class="w-1.5 h-1.5 rounded-full bg-red-400 flex-shrink-0"></div>`;
      html += `<span class="flex-1 truncate text-gray-800">${it.name}</span>`;
      if (dur) html += `<span class="text-[10px] text-red-400 font-mono flex-shrink-0">${dur}</span>`;
      html += '</div>';
    });
    html += '</div>';
    el.innerHTML = html;
  } catch(e) { el.innerHTML = ''; }
}

loadData();
</script>
</body>
</html>
