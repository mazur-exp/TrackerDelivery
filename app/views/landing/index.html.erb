<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= t('landing.page_title') %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#16A34A',
            'primary-dark': '#15803D',
            'primary-light': '#4ADE80',
            'green-50': '#F0FDF4',
            'green-100': '#DCFCE7',
            'green-600': '#16A34A',
            'green-700': '#15803D',
          }
        }
      }
    }
  </script>
</head>
<body class="min-h-screen bg-white">
  <!-- Header -->
  <header class="border-b bg-white/95 backdrop-blur sticky top-0 z-50">
    <div class="container mx-auto px-4 py-4 flex items-center justify-between">
      <div class="flex items-center space-x-2">
        <div class="w-8 h-8 bg-green-600 rounded-lg flex items-center justify-center">
          <i data-lucide="monitor" class="w-5 h-5 text-white"></i>
        </div>
        <span class="text-xl font-bold text-gray-900"><%= t('landing.header.brand_name') %></span>
      </div>
      
      <!-- Mobile Sign In Button (visible only on small screens) -->
      <div class="md:hidden">
        <a href="/login" class="border border-gray-300 hover:bg-gray-50 px-4 py-2 rounded-md text-sm font-medium transition-colors"><%= t('landing.header.sign_in') %></a>
      </div>

      <!-- Desktop Navigation (hidden on small screens) -->
      <nav class="hidden md:flex items-center space-x-6">
        <a href="#features" class="text-gray-600 hover:text-gray-900 transition-colors"><%= t('landing.header.features') %></a>
        <a href="#pricing" class="text-gray-600 hover:text-gray-900 transition-colors"><%= t('landing.header.pricing') %></a>
        <a href="https://t.me/mazur_exp" target="_blank" class="text-gray-600 hover:text-gray-900 transition-colors"><%= t('landing.header.contact') %></a>
        <a href="/login" class="border border-gray-300 hover:bg-gray-50 px-4 py-2 rounded-md text-sm font-medium transition-colors"><%= t('landing.header.sign_in') %></a>
        <a href="/signup" class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-md text-sm font-medium transition-colors"><%= t('landing.header.try_for_free') %></a>
      </nav>
    </div>
  </header>

  <!-- Hero Section -->
  <section class="py-20 px-4">
    <div class="container mx-auto text-center max-w-4xl">
      <div class="inline-flex items-center px-3 py-1 rounded-full bg-green-50 text-green-700 border border-green-200 text-sm font-medium mb-6">
        <%= t('landing.hero.badge') %>
      </div>
      <h1 class="text-4xl md:text-6xl font-bold text-gray-900 mb-6 leading-tight">
        <%= t('landing.hero.title') %>
        <span class="text-green-600 block"><%= t('landing.hero.title_highlight') %></span>
      </h1>
      <p class="text-xl text-gray-600 mb-8 leading-relaxed max-w-2xl mx-auto">
        <%= t('landing.hero.subtitle') %>
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
        <a href="/signup" class="inline-flex items-center justify-center bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-md text-lg font-medium transition-colors">
          <%= t('landing.hero.start_free_trial') %>
          <i data-lucide="arrow-right" class="ml-2 w-4 h-4"></i>
        </a>
        <button class="inline-flex items-center justify-center border-2 border-green-600 text-green-600 hover:bg-green-50 px-8 py-3 rounded-md text-lg font-medium transition-colors">
          <%= t('landing.hero.watch_demo') %>
        </button>
      </div>
      
      <!-- Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mt-16">
        <div class="text-center">
          <div class="flex justify-center mb-2 text-green-600">
            <i data-lucide="check-circle" class="w-6 h-6"></i>
          </div>
          <div class="text-3xl font-bold text-gray-900 mb-1"><%= t('landing.stats.uptime_monitoring') %></div>
          <div class="text-gray-600"><%= t('landing.stats.uptime_label') %></div>
        </div>
        <div class="text-center">
          <div class="flex justify-center mb-2 text-green-600">
            <i data-lucide="clock" class="w-6 h-6"></i>
          </div>
          <div class="text-3xl font-bold text-gray-900 mb-1"><%= t('landing.stats.alert_response') %></div>
          <div class="text-gray-600"><%= t('landing.stats.alert_response_label') %></div>
        </div>
        <div class="text-center">
          <div class="flex justify-center mb-2 text-green-600">
            <i data-lucide="users" class="w-6 h-6"></i>
          </div>
          <div class="text-3xl font-bold text-gray-900 mb-1"><%= t('landing.stats.restaurants_monitored') %></div>
          <div class="text-gray-600"><%= t('landing.stats.restaurants_label') %></div>
        </div>
        <div class="text-center">
          <div class="flex justify-center mb-2 text-green-600">
            <i data-lucide="star" class="w-6 h-6"></i>
          </div>
          <div class="text-3xl font-bold text-gray-900 mb-1"><%= t('landing.stats.customer_rating') %></div>
          <div class="text-gray-600"><%= t('landing.stats.customer_rating_label') %></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section id="features" class="py-20 px-4 bg-gray-50">
    <div class="container mx-auto">
      <div class="text-center mb-16">
        <div class="inline-flex items-center px-3 py-1 rounded-full bg-green-50 text-green-700 border border-green-200 text-sm font-medium mb-4">
          <%= t('landing.features.badge') %>
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          <%= t('landing.features.title') %>
        </h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          <%= t('landing.features.subtitle') %>
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
        <!-- Feature 1 -->
        <div class="bg-white p-6 rounded-xl border hover:shadow-lg transition-all duration-300 hover:-translate-y-1">
          <div class="w-12 h-12 bg-green-50 rounded-lg flex items-center justify-center mb-4">
            <i data-lucide="monitor" class="w-6 h-6 text-green-600"></i>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2"><%= t('landing.features.feature_1_title') %></h3>
          <p class="text-gray-600 leading-relaxed"><%= t('landing.features.feature_1_description') %></p>
        </div>

        <!-- Feature 2 -->
        <div class="bg-white p-6 rounded-xl border hover:shadow-lg transition-all duration-300 hover:-translate-y-1">
          <div class="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4">
            <i data-lucide="bell" class="w-6 h-6 text-blue-600"></i>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2"><%= t('landing.features.feature_2_title') %></h3>
          <p class="text-gray-600 leading-relaxed"><%= t('landing.features.feature_2_description') %></p>
        </div>

        <!-- Feature 3 -->
        <div class="bg-white p-6 rounded-xl border hover:shadow-lg transition-all duration-300 hover:-translate-y-1">
          <div class="w-12 h-12 bg-purple-50 rounded-lg flex items-center justify-center mb-4">
            <i data-lucide="package" class="w-6 h-6 text-purple-600"></i>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2"><%= t('landing.features.feature_3_title') %></h3>
          <p class="text-gray-600 leading-relaxed"><%= t('landing.features.feature_3_description') %></p>
        </div>

        <!-- Feature 4 -->
        <div class="bg-white p-6 rounded-xl border hover:shadow-lg transition-all duration-300 hover:-translate-y-1">
          <div class="w-12 h-12 bg-orange-50 rounded-lg flex items-center justify-center mb-4">
            <i data-lucide="message-square" class="w-6 h-6 text-orange-600"></i>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2"><%= t('landing.features.feature_4_title') %></h3>
          <p class="text-gray-600 leading-relaxed"><%= t('landing.features.feature_4_description') %></p>
        </div>
      </div>

      <!-- Benefits -->
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-12 h-12 bg-green-600 rounded-full flex items-center justify-center mx-auto mb-4 text-white">
            <i data-lucide="trending-up" class="w-5 h-5"></i>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2"><%= t('landing.features.benefit_1_title') %></h3>
          <p class="text-gray-600"><%= t('landing.features.benefit_1_description') %></p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 bg-green-600 rounded-full flex items-center justify-center mx-auto mb-4 text-white">
            <i data-lucide="shield" class="w-5 h-5"></i>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2"><%= t('landing.features.benefit_2_title') %></h3>
          <p class="text-gray-600"><%= t('landing.features.benefit_2_description') %></p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 bg-green-600 rounded-full flex items-center justify-center mx-auto mb-4 text-white">
            <i data-lucide="zap" class="w-5 h-5"></i>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2"><%= t('landing.features.benefit_3_title') %></h3>
          <p class="text-gray-600"><%= t('landing.features.benefit_3_description') %></p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 px-4">
    <div class="container mx-auto">
      <div class="text-center mb-16">
        <div class="inline-flex items-center px-3 py-1 rounded-full bg-green-50 text-green-700 border border-green-200 text-sm font-medium mb-4">
          <%= t('landing.how_it_works.badge') %>
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          <%= t('landing.how_it_works.title') %>
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="w-16 h-16 bg-green-600 rounded-full flex items-center justify-center mx-auto mb-4 text-white text-xl font-bold">
            1
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2"><%= t('landing.how_it_works.step_1_title') %></h3>
          <p class="text-gray-600"><%= t('landing.how_it_works.step_1_description') %></p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-green-600 rounded-full flex items-center justify-center mx-auto mb-4 text-white text-xl font-bold">
            2
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2"><%= t('landing.how_it_works.step_2_title') %></h3>
          <p class="text-gray-600"><%= t('landing.how_it_works.step_2_description') %></p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-green-600 rounded-full flex items-center justify-center mx-auto mb-4 text-white text-xl font-bold">
            3
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2"><%= t('landing.how_it_works.step_3_title') %></h3>
          <p class="text-gray-600"><%= t('landing.how_it_works.step_3_description') %></p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 bg-green-600">
    <div class="container mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        <%= t('landing.cta.title') %>
      </h2>
      <p class="text-xl text-green-100 mb-8 max-w-2xl mx-auto">
        <%= t('landing.cta.subtitle') %>
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/signup" class="inline-flex items-center justify-center bg-white text-green-600 hover:bg-gray-50 px-8 py-3 rounded-md text-lg font-medium transition-colors">
          <%= t('landing.cta.start_free_trial') %>
          <i data-lucide="arrow-right" class="ml-2 w-4 h-4"></i>
        </a>
        <button class="inline-flex items-center justify-center border-2 border-white text-white hover:bg-white hover:text-green-600 px-8 py-3 rounded-md text-lg font-medium transition-colors">
          <%= t('landing.cta.watch_demo') %>
        </button>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-12 px-4 border-t">
    <div class="container mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <div class="flex items-center space-x-2 mb-4 md:mb-0">
          <div class="w-8 h-8 bg-green-600 rounded-lg flex items-center justify-center">
            <i data-lucide="monitor" class="w-5 h-5 text-white"></i>
          </div>
          <span class="text-xl font-bold text-gray-900"><%= t('landing.footer.brand_name') %></span>
        </div>
        <div class="flex space-x-6 text-gray-600">
          <a href="#" class="hover:text-gray-900 transition-colors"><%= t('landing.footer.privacy') %></a>
          <a href="#" class="hover:text-gray-900 transition-colors"><%= t('landing.footer.terms') %></a>
          <a href="#" class="hover:text-gray-900 transition-colors"><%= t('landing.footer.support') %></a>
        </div>
      </div>
      <div class="mt-8 pt-8 border-t text-center text-gray-600">
        <p><%= t('landing.footer.copyright') %></p>
      </div>
    </div>
  </footer>

  <script>
    lucide.createIcons();
  </script>
</body>
</html>
