        formData.notifications.whatsapp = true;
        document.getElementById('whatsapp').checked = true;
        document.getElementById('whatsapp-input').classList.remove('hidden');
        document.getElementById('whatsappNumber').value = existingWhatsapp.join(', ');
        updateContactPreview('whatsapp', existingWhatsapp);
        autoFilledCount++;
      }
      
      if (existingTelegram && existingTelegram.length > 0) {
        formData.telegramContacts = existingTelegram;
        formData.notifications.telegram = true;
        document.getElementById('telegram').checked = true;
        document.getElementById('telegram-input').classList.remove('hidden');
        document.getElementById('telegramUsername').value = existingTelegram.join(', ');
        updateContactPreview('telegram', existingTelegram);
        autoFilledCount++;
      }
      
      if (existingEmail && existingEmail.length > 0) {
        formData.emailContacts = existingEmail;
        formData.notifications.email = true;
        document.getElementById('email').checked = true;
        document.getElementById('email-input').classList.remove('hidden');
        document.getElementById('emailAddress').value = existingEmail.join(', ');
        updateContactPreview('email', existingEmail);
        autoFilledCount++;
      }
      
      // Show auto-fill notification and info box if any contacts were filled
      if (autoFilledCount > 0) {
        
      }
    <% else %>
      // For non-logged in users, they don't have restaurants
      const userHasRestaurants = false;
      const existingWhatsapp = [];
      const existingTelegram = [];
      const existingEmail = [];
    <% end %>

    // Initialize
    showStep(1);
  </script>
