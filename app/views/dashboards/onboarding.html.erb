    function prevStep() {
      if (currentStep === 1 && userHasRestaurants) {
        // On first step with existing restaurants, go back to dashboard
        window.location.href = '/dashboard';
      } else if (currentStep === 2) {
        // In platform review mode - handle platform navigation
        if (currentPlatformIndex > 0) {
          // Go back to previous platform review
          currentPlatformIndex--;
          showPlatformReview(platformsToShow[currentPlatformIndex]);
        } else {
          // On first platform review - go back to URL input (step 1)
          showStep(currentStep - 1);
        }
      } else if (currentStep > 1) {
        showStep(currentStep - 1);
      }
    }

    // Event listeners
    document.getElementById('prevBtn').addEventListener('click', prevStep);
    document.getElementById('nextBtn').addEventListener('click', nextStep);

    // URL validation with automatic extraction and platform detection
    document.getElementById('grabUrl').addEventListener('input', function(e) {
      handleUrlInput(e.target, 'grab');
    });

    document.getElementById('gofoodUrl').addEventListener('input', function(e) {
      handleUrlInput(e.target, 'gofood');
    });

    // Handle paste events for better URL extraction
    document.getElementById('grabUrl').addEventListener('paste', function(e) {
      setTimeout(() => handleUrlInput(e.target, 'grab'), 10);
    });

    document.getElementById('gofoodUrl').addEventListener('paste', function(e) {
      setTimeout(() => handleUrlInput(e.target, 'gofood'), 10);
    });

    // Form input handlers removed since form fields no longer exist on step 2

    // Notification checkboxes
    ['whatsapp', 'telegram', 'email'].forEach(channel => {
      document.getElementById(channel).addEventListener('change', function(e) {
        formData.notifications[channel] = e.target.checked;
        const input = document.getElementById(`${channel}-input`);
        
        if (e.target.checked) {
          input.classList.remove('hidden');
        } else {
          input.classList.add('hidden');
        }
        
        updateButtons();
      });
    });

    // Notification inputs with contact parsing
    document.getElementById('whatsappNumber').addEventListener('input', function(e) {
      const contacts = parseContacts(e.target.value, 'whatsapp');
      formData.whatsappContacts = contacts;
      updateContactPreview('whatsapp', contacts);
      updateButtons();
    });

    document.getElementById('telegramUsername').addEventListener('input', function(e) {
      const contacts = parseContacts(e.target.value, 'telegram');
      formData.telegramContacts = contacts;
      updateContactPreview('telegram', contacts);
      updateButtons();
    });

    document.getElementById('emailAddress').addEventListener('input', function(e) {
      const contacts = parseContacts(e.target.value, 'email');
      formData.emailContacts = contacts;
      updateContactPreview('email', contacts);
      updateButtons();
    });

