<% content_for :title, "Reset Password - DeliveryTracker" %>

<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>

<div class="min-h-screen bg-white flex items-center justify-center px-4 py-8">
  <div class="max-w-md w-full">
    <!-- Logo/Brand -->
    <div class="text-center mb-8">
      <div class="flex items-center justify-center space-x-2 mb-4">
        <div class="w-8 h-8 bg-green-600 rounded-lg flex items-center justify-center">
          <i data-lucide="monitor" class="w-5 h-5 text-white"></i>
        </div>
        <span class="text-xl font-bold text-gray-900">DeliveryTracker</span>
      </div>
      <p class="text-gray-600">Monitor your restaurant delivery platforms</p>
    </div>

    <!-- Password Reset Form Card -->
    <div class="bg-white rounded-xl border shadow-sm p-8">
      <div class="text-center mb-6">
        <div class="mx-auto w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mb-4">
          <i data-lucide="lock" class="w-8 h-8 text-green-600"></i>
        </div>
        <h2 class="text-2xl font-semibold text-gray-900">Reset Password</h2>
        <p class="text-gray-600 mt-1">We'll email you reset instructions</p>
      </div>

      <%= form_with url: forgot_password_path, local: true, class: "space-y-6" do |form| %>
        <!-- Email Field -->
        <div>
          <%= form.label :email_address, "Email Address", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.email_field :email_address, 
              placeholder: "you@restaurant.com",
              required: true,
              class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-green-600/20 focus:border-green-600 transition-all duration-300" %>
          <p class="text-xs text-gray-500 mt-1">Enter the email address associated with your account</p>
        </div>

        <!-- Submit Button -->
        <div>
          <%= form.submit "Send Reset Instructions", 
              class: "w-full bg-green-600 hover:bg-green-700 text-white font-medium py-3 px-4 rounded-md transition-colors duration-200" %>
        </div>
      <% end %>

      <!-- Info Box -->
      <div class="mt-6 p-4 bg-green-50 rounded-lg border border-green-200">
        <div class="flex items-start">
          <div class="flex-shrink-0">
            <i data-lucide="info" class="w-5 h-5 text-green-600 mt-0.5"></i>
          </div>
          <div class="ml-3">
            <p class="text-sm text-green-700">
              <strong>Security Note:</strong> If an account exists with that email, you'll receive reset instructions.
            </p>
            <p class="text-xs text-green-600 mt-1">
              Reset links expire after 2 hours for your security.
            </p>
          </div>
        </div>
      </div>

      <!-- Back to Login -->
      <div class="text-center mt-6">
        <%= link_to "← Back to Sign In", login_path, 
            class: "text-sm text-green-600 hover:text-green-700 underline" %>
      </div>
    </div>
  </div>
</div>

<script>
  lucide.createIcons();
</script>