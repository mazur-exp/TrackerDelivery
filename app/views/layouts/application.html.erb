<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Delivery Tracking - Never Miss Platform Closures" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="icon" href="/favicon-16x16.png" sizes="16x16" type="image/png">
    <link rel="icon" href="/favicon-32x32.png" sizes="32x32" type="image/png">
    <link rel="apple-touch-icon" href="/icon-192x192.png" sizes="192x192">
    <link rel="manifest" href="/site.webmanifest">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <!-- Flash Messages -->
    <% if flash.any? %>
      <div class="flash-messages">
        <% flash.each do |type, message| %>
          <div class="flash-<%= type %> flash-message fixed z-50 <%= type == 'notice' ? 'bg-green-50 border-l-4 border-green-500' : 'bg-red-50 border-l-4 border-red-500' %> rounded-lg shadow-xl" style="animation: slideInDown 0.3s ease-out;">
            <div class="p-4">
              <div class="flex items-start">
                <div class="flex-shrink-0">
                  <% if type == 'notice' %>
                    <div class="flex items-center justify-center w-8 h-8 bg-green-100 rounded-full">
                      <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                      </svg>
                    </div>
                  <% else %>
                    <div class="flex items-center justify-center w-8 h-8 bg-red-100 rounded-full">
                      <svg class="w-5 h-5 text-red-600" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
                      </svg>
                    </div>
                  <% end %>
                </div>
                <div class="ml-3 flex-1">
                  <p class="text-sm font-semibold <%= type == 'notice' ? 'text-green-800' : 'text-red-800' %>">
                    <%= message %>
                  </p>
                </div>
                <div class="flex-shrink-0 ml-4">
                  <button class="inline-flex text-gray-400 hover:text-gray-500 focus:outline-none transition-colors">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
      
      <style>
        @keyframes slideInDown {
          from { 
            opacity: 0; 
            transform: translate(-50%, -20px) scale(0.95); 
          }
          to { 
            opacity: 1; 
            transform: translate(-50%, 0) scale(1); 
          }
        }
        @keyframes slideOutUp {
          from { 
            opacity: 1; 
            transform: translate(-50%, 0) scale(1); 
          }
          to { 
            opacity: 0; 
            transform: translate(-50%, -20px) scale(0.95); 
          }
        }
        .flash-messages > div {
          animation: slideInDown 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .flash-messages > div.removing {
          animation: slideOutUp 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }
      </style>
      
      <script>
        // Position flash messages based on page layout
        function positionFlashMessages() {
          const flashMessages = document.querySelectorAll('.flash-message');
          
          // Check for various types of headers/navigation
          const hasHeader = document.querySelector('nav, header, .header') || 
                           document.querySelector('[class*="header"]') || 
                           document.querySelector('.max-w-7xl') ||
                           document.querySelector('.navbar') ||
                           document.querySelector('[class*="nav"]') ||
                           // Check for navigation menu items
                           (document.querySelector('a[href*="pricing"]') && document.querySelector('a[href*="contact"]')) ||
                           // Check for specific landing page elements
                           document.querySelector('.flex.items-center.justify-between') ||
                           // Check current page URL
                           (window.location.pathname === '/' || window.location.pathname === '/index');
          
          flashMessages.forEach(function(flash) {
            if (hasHeader) {
              flash.style.top = '5rem'; // 80px for pages with header
            } else {
              flash.style.top = '1.5rem'; // 24px for pages without header (like login)
            }
            
            // Perfect centering
            flash.style.left = '50%';
            flash.style.transform = 'translateX(-50%)';
            flash.style.maxWidth = '28rem'; // 448px
            flash.style.width = 'auto';
            flash.style.minWidth = '20rem'; // 320px minimum
            flash.style.margin = '0';
            flash.style.padding = '0';
            
            // Ensure it doesn't go beyond screen edges on mobile
            const viewportWidth = window.innerWidth;
            if (viewportWidth < 480) {
              flash.style.maxWidth = 'calc(100vw - 2rem)';
              flash.style.left = '1rem';
              flash.style.right = '1rem';
              flash.style.transform = 'none';
              flash.style.width = 'auto';
            }
          });
        }
        
        // Position messages on page load
        positionFlashMessages();
        
        // Reposition on window resize
        window.addEventListener('resize', positionFlashMessages);

        // Auto-hide flash messages after 6 seconds
        setTimeout(function() {
          document.querySelectorAll('.flash-messages > div').forEach(function(flash) {
            flash.classList.add('removing');
            setTimeout(function() { 
              if (flash.parentNode) {
                flash.remove(); 
              }
            }, 300);
          });
        }, 6000);

        // Smooth close animation for manual close
        document.addEventListener('click', function(e) {
          const button = e.target.closest('.flash-messages button');
          if (button) {
            e.preventDefault();
            const flashMessage = button.closest('.flash-notice, .flash-alert');
            if (flashMessage) {
              flashMessage.classList.add('removing');
              setTimeout(function() {
                if (flashMessage.parentNode) {
                  flashMessage.remove();
                }
              }, 300);
            }
          }
        });
      </script>
    <% end %>
    
    <%= yield %>
  </body>
</html>
