<% content_for :title, "#{t('auth.sign_in')} - DeliveryTracker" %>
<%
  # Prefix session token with locale for Telegram bot
  base_token = SecureRandom.urlsafe_base64(32)
  session_token = I18n.locale == :ru ? "ru_#{base_token}" : base_token
%>

<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>

<div class="min-h-screen bg-white flex items-center justify-center px-4 py-8"
     data-controller="auth"
     data-auth-session-token-value="<%= session_token %>">
  <div class="max-w-md w-full">
    <!-- Logo/Brand -->
    <div class="text-center mb-8">
      <div class="flex items-center justify-center space-x-2 mb-4">
        <div class="w-8 h-8 bg-green-600 rounded-lg flex items-center justify-center">
          <i data-lucide="monitor" class="w-5 h-5 text-white"></i>
        </div>
        <span class="text-xl font-bold text-gray-900">DeliveryTracker</span>
      </div>
      <p class="text-gray-600">Monitor your restaurant delivery platforms</p>
    </div>

    <!-- Login Form Card -->
    <div class="bg-white rounded-xl border shadow-sm p-8">
      <div class="text-center mb-6">
        <h2 class="text-2xl font-semibold text-gray-900"><%= t('auth.sign_in') %></h2>
        <p class="text-gray-600 mt-1"><%= t('auth.sign_in_subtitle') %></p>
      </div>

      <!-- Telegram Login -->
      <div class="flex flex-col items-center justify-center py-8">
        <p class="text-sm text-gray-600 mb-6">
          <%= t('auth.click_button_below') %>
        </p>

        <!-- Telegram Bot Login Button -->
        <a href="https://t.me/<%= ENV['TELEGRAM_BOT_USERNAME'] || 'delivery_tracker_auth_bot' %>?start=<%= session_token %>"
           target="_blank"
           class="inline-flex items-center justify-center px-6 py-3 bg-blue-500 hover:bg-blue-600 text-white font-medium rounded-lg transition-colors duration-200 shadow-sm hover:shadow-md">
          <svg class="w-6 h-6 mr-2" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.562 8.161c-.18 1.897-.962 6.502-1.359 8.627-.168.9-.5 1.201-.82 1.23-.697.064-1.226-.461-1.901-.903-1.056-.693-1.653-1.124-2.678-1.8-1.185-.781-.417-1.21.258-1.911.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.248-.024c-.106.024-1.793 1.139-5.062 3.345-.479.329-.913.489-1.302.481-.428-.009-1.252-.242-1.865-.442-.752-.244-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.831-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635.099-.002.321.023.465.14.121.099.155.233.171.326.016.094.037.308.021.475z"/>
          </svg>
          <%= t('auth.sign_in_with_telegram') %>
        </a>

        <div class="mt-6 p-4 bg-blue-50 rounded-lg border border-blue-200 max-w-sm">
          <div class="flex items-start">
            <div class="flex-shrink-0">
              <i data-lucide="info" class="w-5 h-5 text-blue-600 mt-0.5"></i>
            </div>
            <div class="ml-3">
              <p class="text-xs text-blue-700">
                <strong><%= t('auth.how_it_works') %></strong><br>
                1. <%= t('auth.step_1') %><br>
                2. <%= t('auth.step_2') %><br>
                3. <%= t('auth.step_3') %><br>
                4. <%= t('auth.step_4_login') %>
              </p>
            </div>
          </div>
        </div>
      </div>

