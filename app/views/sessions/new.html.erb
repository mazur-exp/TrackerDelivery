<% content_for :title, "Sign In - DeliveryTracker" %>

<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>

<div class="min-h-screen bg-white flex items-center justify-center px-4 py-8">
  <div class="max-w-md w-full">
    <!-- Logo/Brand -->
    <div class="text-center mb-8">
      <div class="flex items-center justify-center space-x-2 mb-4">
        <div class="w-8 h-8 bg-green-600 rounded-lg flex items-center justify-center">
          <i data-lucide="monitor" class="w-5 h-5 text-white"></i>
        </div>
        <span class="text-xl font-bold text-gray-900">DeliveryTracker</span>
      </div>
      <p class="text-gray-600">Monitor your restaurant delivery platforms</p>
    </div>

    <!-- Login Form Card -->
    <div class="bg-white rounded-xl border shadow-sm p-8">
      <div class="text-center mb-6">
        <h2 class="text-2xl font-semibold text-gray-900">Sign In</h2>
        <p class="text-gray-600 mt-1">Sign in to your account</p>
      </div>

      <%= form_with url: login_path, local: true, class: "space-y-6" do |form| %>
        <!-- Email Field -->
        <div>
          <%= form.label :email_address, "Email Address", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.email_field :email_address, 
              placeholder: "you@restaurant.com",
              required: true,
              class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-green-600/20 focus:border-green-600 transition-all duration-300" %>
        </div>

        <!-- Password Field -->
        <div>
          <div class="flex items-center justify-between mb-2">
            <%= form.label :password, class: "block text-sm font-medium text-gray-700" %>
            <%= link_to "Forgot password?", forgot_password_path, 
                class: "text-sm text-green-600 hover:text-green-700" %>
          </div>
          <%= form.password_field :password, 
              placeholder: "Your password",
              required: true,
              class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-green-600/20 focus:border-green-600 transition-all duration-300" %>
        </div>

        <!-- Submit Button -->
        <div>
          <%= form.submit "Sign In", 
              class: "w-full bg-green-600 hover:bg-green-700 text-white font-medium py-3 px-4 rounded-md transition-colors duration-200" %>
        </div>
      <% end %>

      <!-- Divider -->
      <div class="relative my-6">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-gray-200"></div>
        </div>
        <div class="relative flex justify-center text-sm">
          <span class="px-2 bg-white text-gray-500">New to DeliveryTracker?</span>
        </div>
      </div>

      <!-- Signup Link -->
      <div class="text-center">
        <%= link_to "Create Account", signup_path, 
            class: "inline-flex items-center justify-center w-full py-3 px-4 border border-gray-300 rounded-md text-gray-700 font-medium hover:bg-gray-50 transition-colors duration-200" %>
      </div>

      <!-- Email Confirmation Help -->
      <div class="mt-6 p-4 bg-green-50 rounded-lg border border-green-200">
        <div class="flex items-start">
          <div class="flex-shrink-0">
            <i data-lucide="info" class="w-5 h-5 text-green-600 mt-0.5"></i>
          </div>
          <div class="ml-3">
            <p class="text-sm text-green-700">
              <strong>First time signing in?</strong> Check your email for a confirmation link after creating your account.
              <br>
              <% if params[:email_confirmation] == "required" %>
                <span class="text-green-700">Please confirm your email address first.</span>
              <% end %>
            </p>
            <p class="text-xs text-green-600 mt-2">
              <%= link_to "Need to resend confirmation?", resend_confirmation_path, class: "underline hover:no-underline" %>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  lucide.createIcons();
</script>