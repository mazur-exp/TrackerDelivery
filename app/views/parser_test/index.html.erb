<div class="min-h-screen bg-gradient-to-br from-slate-50 via-white to-blue-50 py-12 px-4">
  <div class="max-w-5xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold bg-gradient-to-r from-blue-600 to-indigo-700 bg-clip-text text-transparent mb-4">
        HTTP Parser Testing
      </h1>
      <p class="text-slate-600 text-lg">
        Test Grab and GoJek HTTP parsers in production environment
      </p>
      <div class="mt-4 inline-flex items-center gap-2 px-4 py-2 bg-white/80 backdrop-blur-sm rounded-full shadow-sm border border-slate-200">
        <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
        <span class="text-sm text-slate-700">Production Environment</span>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      <!-- Grab Parser Card -->
      <div class="bg-white rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-300 overflow-hidden border border-slate-100">
        <div class="bg-gradient-to-r from-orange-500 to-pink-600 p-6">
          <h2 class="text-2xl font-bold text-white mb-2">🍔 Grab Parser</h2>
          <p class="text-white/90 text-sm">API v2 + JWT Authentication</p>
        </div>

        <div class="p-6">
          <form id="grab-form" class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-2">
                Grab Restaurant URL
              </label>
              <input
                type="url"
                id="grab-url"
                placeholder="https://r.grab.com/g/6-..."
                class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-all"
                value="https://r.grab.com/g/6-20250920_121514_8015D1829687499383E150126C5CEFCA_MEXMPS-6-C65ZV62KVNEDPE"
              />
            </div>

            <button
              type="submit"
              class="w-full py-3 px-6 bg-gradient-to-r from-orange-500 to-pink-600 text-white font-semibold rounded-xl hover:shadow-lg transform hover:-translate-y-0.5 transition-all duration-200"
            >
              Test Grab Parser
            </button>
          </form>

          <!-- Results -->
          <div id="grab-results" class="mt-6 hidden">
            <div class="p-4 bg-slate-50 rounded-xl">
              <div class="flex items-center justify-between mb-3">
                <h3 class="font-semibold text-slate-900">Results:</h3>
                <span id="grab-duration" class="text-sm text-slate-600"></span>
              </div>
              <pre id="grab-data" class="text-xs bg-white p-3 rounded-lg overflow-auto max-h-96 border border-slate-200"></pre>
            </div>
          </div>

          <div id="grab-error" class="mt-6 hidden">
            <div class="p-4 bg-red-50 border border-red-200 rounded-xl">
              <h3 class="font-semibold text-red-900 mb-2">Error:</h3>
              <pre class="text-sm text-red-700 overflow-auto"></pre>
            </div>
          </div>

          <div id="grab-loading" class="mt-6 hidden">
            <div class="flex items-center gap-3 p-4 bg-blue-50 rounded-xl">
              <div class="w-5 h-5 border-3 border-blue-600 border-t-transparent rounded-full animate-spin"></div>
              <span class="text-blue-700">Parsing restaurant data...</span>
            </div>
          </div>
        </div>
      </div>

      <!-- GoJek Parser Card -->
      <div class="bg-white rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-300 overflow-hidden border border-slate-100">
        <div class="bg-gradient-to-r from-green-500 to-emerald-600 p-6">
          <h2 class="text-2xl font-bold text-white mb-2">🍜 GoJek Parser</h2>
          <p class="text-white/90 text-sm">__NEXT_DATA__ + Cookies</p>
        </div>

        <div class="p-6">
          <form id="gojek-form" class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-2">
                GoFood Restaurant URL
              </label>
              <input
                type="url"
                id="gojek-url"
                placeholder="https://gofood.link/a/..."
                class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all"
                value="https://gofood.link/a/MrswDDW"
              />
            </div>

            <button
              type="submit"
              class="w-full py-3 px-6 bg-gradient-to-r from-green-500 to-emerald-600 text-white font-semibold rounded-xl hover:shadow-lg transform hover:-translate-y-0.5 transition-all duration-200"
            >
              Test GoJek Parser
            </button>
          </form>

          <!-- Results -->
          <div id="gojek-results" class="mt-6 hidden">
            <div class="p-4 bg-slate-50 rounded-xl">
              <div class="flex items-center justify-between mb-3">
                <h3 class="font-semibold text-slate-900">Results:</h3>
                <span id="gojek-duration" class="text-sm text-slate-600"></span>
              </div>
              <pre id="gojek-data" class="text-xs bg-white p-3 rounded-lg overflow-auto max-h-96 border border-slate-200"></pre>
            </div>
          </div>

          <div id="gojek-error" class="mt-6 hidden">
            <div class="p-4 bg-red-50 border border-red-200 rounded-xl">
              <h3 class="font-semibold text-red-900 mb-2">Error:</h3>
              <pre class="text-sm text-red-700 overflow-auto"></pre>
            </div>
          </div>

          <div id="gojek-loading" class="mt-6 hidden">
            <div class="flex items-center gap-3 p-4 bg-blue-50 rounded-xl">
              <div class="w-5 h-5 border-3 border-green-600 border-t-transparent rounded-full animate-spin"></div>
              <span class="text-green-700">Parsing restaurant data...</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Info Card -->
    <div class="mt-8 bg-white/80 backdrop-blur-sm rounded-2xl shadow-lg p-6 border border-slate-200">
      <h3 class="font-semibold text-slate-900 mb-3">ℹ️ Testing Information</h3>
      <ul class="space-y-2 text-sm text-slate-700">
        <li class="flex items-start gap-2">
          <span class="text-blue-600">→</span>
          <span><strong>Grab Parser:</strong> Uses official Guest API v2 with JWT authentication</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-600">→</span>
          <span><strong>GoJek Parser:</strong> Extracts __NEXT_DATA__ JSON from HTML with cookies</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-orange-600">→</span>
          <span><strong>Expected Performance:</strong> ~0.5-2 seconds per restaurant</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-purple-600">→</span>
          <span><strong>Data Quality:</strong> 95-100% accuracy</span>
        </li>
      </ul>
    </div>
  </div>
</div>

<script>
  // Grab Parser Form Handler
  document.getElementById('grab-form').addEventListener('submit', async (e) => {
    e.preventDefault();

    const url = document.getElementById('grab-url').value;
    const loading = document.getElementById('grab-loading');
    const results = document.getElementById('grab-results');
    const error = document.getElementById('grab-error');

    // Reset UI
    loading.classList.remove('hidden');
    results.classList.add('hidden');
    error.classList.add('hidden');

    try {
      const response = await fetch('/test-parsers/grab', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url })
      });

      const data = await response.json();
      loading.classList.add('hidden');

      if (data.success) {
        document.getElementById('grab-duration').textContent = `⏱️ ${data.duration}s (Quality: ${data.quality}%)`;
        document.getElementById('grab-data').textContent = JSON.stringify(data.data, null, 2);
        results.classList.remove('hidden');
      } else {
        error.querySelector('pre').textContent = data.error || 'Unknown error';
        error.classList.remove('hidden');
      }
    } catch (err) {
      loading.classList.add('hidden');
      error.querySelector('pre').textContent = `Network error: ${err.message}`;
      error.classList.remove('hidden');
    }
  });

  // GoJek Parser Form Handler
  document.getElementById('gojek-form').addEventListener('submit', async (e) => {
    e.preventDefault();

    const url = document.getElementById('gojek-url').value;
    const loading = document.getElementById('gojek-loading');
    const results = document.getElementById('gojek-results');
    const error = document.getElementById('gojek-error');

    // Reset UI
    loading.classList.remove('hidden');
    results.classList.add('hidden');
    error.classList.add('hidden');

    try {
      const response = await fetch('/test-parsers/gojek', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url })
      });

      const data = await response.json();
      loading.classList.add('hidden');

      if (data.success) {
        document.getElementById('gojek-duration').textContent = `⏱️ ${data.duration}s (Quality: ${data.quality}%)`;
        document.getElementById('gojek-data').textContent = JSON.stringify(data.data, null, 2);
        results.classList.remove('hidden');
      } else {
        error.querySelector('pre').textContent = data.error || 'Unknown error';
        error.classList.remove('hidden');
      }
    } catch (err) {
      loading.classList.add('hidden');
      error.querySelector('pre').textContent = `Network error: ${err.message}`;
      error.classList.remove('hidden');
    }
  });
</script>
