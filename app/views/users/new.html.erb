      </div>
    </div>

    <!-- Terms -->
    <p class="text-center text-xs text-gray-500 mt-6">
      <%= t('auth.terms_text') %>
      <a href="#" class="text-green-600 hover:text-green-700"><%= t('auth.terms_of_service') %></a>
      <%= t('auth.and') %>
      <a href="#" class="text-green-600 hover:text-green-700"><%= t('auth.privacy_policy') %></a>
    </p>
  </div>
</div>

<script>
  lucide.createIcons();
