      console.log('🔄 Clearing auto-fill data');
      
      // Clear form data
      formData.whatsappContacts = [];
      formData.telegramContacts = [];
      formData.emailContacts = [];
      formData.notifications = { whatsapp: false, telegram: false, email: false };
      
      // Reset UI elements
      ['whatsapp', 'telegram', 'email'].forEach(type => {
        const checkbox = document.getElementById(type);
        const inputSection = document.getElementById(`${type}-input`);
