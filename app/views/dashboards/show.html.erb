<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= form_authenticity_token %>">
  <title><%= t('dashboard.page_title') %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#16A34A',
            'primary-dark': '#15803D',
            'primary-light': '#4ADE80',
            'green-50': '#F0FDF4',
            'green-100': '#DCFCE7',
            'green-600': '#16A34A',
            'green-700': '#15803D',
          }
        }
      }
    }
  </script>
  <style>
    #modalContent {
      transition: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
    }
    #logoutModal {
      backdrop-filter: blur(4px);
    }
  </style>
</head>
<body class="min-h-screen bg-gray-50">
  <!-- Logout Confirmation Modal -->
  <div id="logoutModal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 hidden">
    <div class="bg-white rounded-xl shadow-2xl max-w-md w-full mx-4 transform transition-all" id="modalContent">
      <div class="p-6">
        <div class="flex items-center mb-4">
          <div class="flex items-center justify-center w-12 h-12 bg-red-100 rounded-full mr-4">
            <i data-lucide="log-out" class="w-6 h-6 text-red-600"></i>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-gray-900"><%= t('dashboard.logout_modal.title') %></h3>
            <p class="text-sm text-gray-500"><%= t('dashboard.logout_modal.message') %></p>
          </div>
        </div>

        <div class="flex space-x-3">
          <button id="cancelLogout" class="flex-1 px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg font-medium transition-colors">
            <%= t('dashboard.logout_modal.cancel') %>
          </button>
          <button id="confirmLogout" class="flex-1 px-4 py-2 text-white bg-red-600 hover:bg-red-700 rounded-lg font-medium transition-colors">
            <%= t('dashboard.logout_modal.confirm') %>
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="min-h-screen p-4 md:p-6 lg:p-8">
    <div class="max-w-7xl mx-auto space-y-6">
      <!-- Header -->
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
          <div class="flex items-center space-x-2 mb-2">
            <a href="/" class="flex items-center space-x-2">
              <div class="w-8 h-8 bg-green-600 rounded-lg flex items-center justify-center">
                <i data-lucide="monitor" class="w-5 h-5 text-white"></i>
              </div>
              <span class="text-xl font-bold text-gray-900"><%= t('dashboard.header.brand_name') %></span>
            </a>
          </div>
          <h1 class="text-3xl font-bold text-gray-900"><%= t('dashboard.header.title') %></h1>
          <p class="text-gray-600"><%= t('dashboard.header.subtitle') %></p>
        </div>
        <div class="flex items-center gap-3">
          <div class="inline-flex items-center px-3 py-1 rounded-full border text-sm">
            <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse mr-2"></div>
            <%= t('dashboard.header.live') %>
          </div>
          <button id="refreshBtn" class="inline-flex items-center px-3 py-2 border border-gray-300 rounded-md text-sm font-medium hover:bg-gray-50 transition-colors">
            <i data-lucide="refresh-cw" class="w-4 h-4 mr-2"></i>
            <%= t('dashboard.header.refresh') %>
          </button>
          <button id="addRestaurantBtn" class="inline-flex items-center px-3 py-2 border border-green-200 text-green-600 hover:bg-green-50 rounded-md text-sm font-medium transition-colors">
            <i data-lucide="plus" class="w-4 h-4 mr-2"></i>
            <%= t('dashboard.header.add_restaurant') %>
          </button>
          <button id="logoutBtn" onclick="testLogout()" class="inline-flex items-center px-3 py-2 border border-red-200 text-red-600 hover:bg-red-50 rounded-md text-sm font-medium transition-colors">
            <i data-lucide="log-out" class="w-4 h-4 mr-2"></i>
            <%= t('dashboard.header.log_out') %>
          </button>
        </div>
      </div>

      <!-- Overview Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-white rounded-xl border border-green-200 bg-green-50/50 p-6 shadow-sm">
          <div class="flex flex-row items-center justify-between space-y-0 pb-2">
            <h3 class="text-sm font-medium"><%= t('dashboard.overview_cards.total_revenue') %></h3>
            <i data-lucide="dollar-sign" class="h-4 w-4 text-green-600"></i>
          </div>
          <div class="text-2xl font-bold text-green-700" id="totalRevenue">Rp 4,240,000</div>
          <p class="text-xs text-green-600 flex items-center gap-1">
            <i data-lucide="trending-up" class="w-3 h-3"></i>
            <%= t('dashboard.overview_cards.from_yesterday') %>
          </p>
        </div>

        <div class="bg-white rounded-xl border border-blue-200 bg-blue-50/50 p-6 shadow-sm">
          <div class="flex flex-row items-center justify-between space-y-0 pb-2">
            <h3 class="text-sm font-medium"><%= t('dashboard.overview_cards.total_orders') %></h3>
            <i data-lucide="shopping-bag" class="h-4 w-4 text-blue-600"></i>
          </div>
          <div class="text-2xl font-bold text-blue-700" id="totalOrders">135</div>
          <p class="text-xs text-blue-600 flex items-center gap-1">
            <i data-lucide="trending-up" class="w-3 h-3"></i>
            <%= t('dashboard.overview_cards.orders_from_yesterday') %>
          </p>
        </div>

        <div class="bg-white rounded-xl border border-purple-200 bg-purple-50/50 p-6 shadow-sm">
          <div class="flex flex-row items-center justify-between space-y-0 pb-2">
            <h3 class="text-sm font-medium"><%= t('dashboard.overview_cards.online_stores') %></h3>
            <i data-lucide="store" class="h-4 w-4 text-purple-600"></i>
          </div>
          <div class="text-2xl font-bold text-purple-700" id="onlineStores"><%= @total_restaurants %></div>
          <p class="text-xs text-purple-600" id="operationalPercentage"><%= t('dashboard.overview_cards.total_restaurants') %></p>
        </div>

        <div class="bg-white rounded-xl border border-orange-200 bg-orange-50/50 p-6 shadow-sm">
          <div class="flex flex-row items-center justify-between space-y-0 pb-2">
            <h3 class="text-sm font-medium"><%= t('dashboard.overview_cards.avg_rating') %></h3>
            <i data-lucide="star" class="h-4 w-4 text-orange-600"></i>
          </div>
          <div class="text-2xl font-bold text-orange-700" id="avgRating"><%= @average_rating > 0 ? @average_rating : "N/A" %></div>
          <p class="text-xs text-orange-600 flex items-center gap-1">
            <i data-lucide="star" class="w-3 h-3 fill-current"></i>
            <%= t('dashboard.overview_cards.across_all_platforms') %>
          </p>
        </div>
      </div>

      <!-- Main Content Tabs -->
      <div class="space-y-6">
        <!-- Tab Navigation -->
        <div class="bg-gray-100 rounded-lg p-1 inline-flex">
          <button class="tab-btn px-4 py-2 text-sm font-medium rounded-md transition-colors bg-white text-gray-900 shadow-sm" data-tab="restaurants">
            <%= t('dashboard.tabs.restaurants') %>
          </button>
          <button class="tab-btn px-4 py-2 text-sm font-medium rounded-md transition-colors text-gray-500 hover:text-gray-700" data-tab="outofstock">
            <%= t('dashboard.tabs.out_of_stock') %>
          </button>
          <button class="tab-btn px-4 py-2 text-sm font-medium rounded-md transition-colors text-gray-500 hover:text-gray-700" data-tab="reviews">
            <%= t('dashboard.tabs.reviews') %>
          </button>
          <button class="tab-btn px-4 py-2 text-sm font-medium rounded-md transition-colors text-gray-500 hover:text-gray-700" data-tab="settings">
            <%= t('dashboard.tabs.settings') %>
          </button>
        </div>

        <!-- Restaurants Tab -->
        <div id="restaurants-tab" class="tab-content space-y-4">
          <% if @restaurants.present? %>
            <% @restaurants.each do |restaurant| %>
              <div class="<%= restaurant.is_active ? 'bg-white' : 'bg-gray-100' %> rounded-xl border shadow-sm hover:shadow-md transition-shadow p-5 <%= restaurant.is_active ? '' : 'opacity-60' %>" data-restaurant-card="<%= restaurant.id %>">
                <!-- Top row: image + name + status + actions -->
                <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-3">
                  <div class="flex items-center gap-3">
                    <% if restaurant.image_url.present? %>
                      <img src="<%= restaurant.image_url %>" alt="<%= restaurant.name %>" class="w-12 h-12 rounded-lg object-cover flex-shrink-0">
                    <% else %>
                      <div class="w-12 h-12 rounded-lg flex items-center justify-center text-white text-xs font-bold flex-shrink-0 <%= restaurant.platform == 'gojek' ? 'bg-green-500' : 'bg-green-600' %>">
                        <%= restaurant.platform == 'gojek' ? 'GO' : 'GR' %>
                      </div>
                    <% end %>
                    <div class="min-w-0">
                      <h3 class="font-semibold text-base truncate"><%= restaurant.name %></h3>
                      <div class="flex items-center gap-2 text-xs text-gray-500">
                        <span><%= restaurant.platform_name %></span>
                        <% if restaurant.rating.present? && restaurant.rating != "NEW" %>
                          <span class="flex items-center gap-0.5"><i data-lucide="star" class="w-3 h-3 fill-yellow-400 text-yellow-400"></i><%= restaurant.rating %></span>
                        <% end %>
                      </div>
                    </div>
                  </div>

                  <div class="flex items-center gap-3 flex-wrap">
                    <% sd = @status_data[restaurant.id] %>
                    <% if sd %>
                      <!-- Status badge + timer -->
                      <% case sd[:current_status] %>
                      <% when 'open' %>
                        <div class="flex items-center gap-1.5 px-2.5 py-1 bg-green-50 border border-green-200 rounded-lg">
                          <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
                          <span class="text-xs font-semibold text-green-700">OPEN</span>
                          <span class="text-xs text-green-600 font-mono status-timer" data-since="<%= sd[:status_since] %>"></span>
                        </div>
                      <% when 'closed' %>
                        <div class="flex items-center gap-1.5 px-2.5 py-1 bg-red-50 border border-red-200 rounded-lg">
                          <div class="w-2 h-2 rounded-full bg-red-500"></div>
                          <span class="text-xs font-semibold text-red-700">CLOSED</span>
                          <span class="text-xs text-red-600 font-mono status-timer" data-since="<%= sd[:status_since] %>"></span>
                        </div>
                      <% else %>
                        <div class="flex items-center gap-1.5 px-2.5 py-1 bg-gray-50 border border-gray-200 rounded-lg">
                          <div class="w-2 h-2 rounded-full bg-gray-400"></div>
                          <span class="text-xs font-medium text-gray-600"><%= sd[:current_status] %></span>
                        </div>
                      <% end %>

                      <!-- Uptime bar -->
                      <% if sd[:uptime_pct] %>
                        <div class="flex items-center gap-1.5 text-xs">
                          <div class="w-14 h-1.5 bg-gray-200 rounded-full overflow-hidden">
                            <div class="h-full rounded-full <%= sd[:uptime_pct] >= 90 ? 'bg-green-500' : sd[:uptime_pct] >= 50 ? 'bg-yellow-500' : 'bg-red-500' %>" style="width: <%= sd[:uptime_pct] %>%"></div>
                          </div>
                          <span class="text-gray-500"><%= sd[:uptime_pct] %>%</span>
                        </div>
                      <% end %>

                      <!-- OOS badge -->
                      <% if sd[:oos_menu_items] > 0 %>
                        <span class="inline-flex items-center gap-0.5 px-1.5 py-0.5 rounded text-xs font-medium bg-red-100 text-red-700">
                          <i data-lucide="package-x" class="w-3 h-3"></i>
                          <%= sd[:oos_menu_items] %> OOS
                        </span>
                      <% end %>
                    <% else %>
                      <div class="flex items-center gap-1.5 text-xs text-gray-400">
                        <div class="w-2 h-2 rounded-full bg-gray-300"></div>
                        <span><%= t('dashboard.restaurants_tab.not_monitored') %></span>
                      </div>
                    <% end %>

                    <%= link_to analytics_restaurant_path(restaurant), class: "inline-flex items-center gap-1 px-2.5 py-1.5 bg-green-600 hover:bg-green-700 text-white text-xs font-medium rounded-lg transition-colors" do %>
                      <i data-lucide="bar-chart-3" class="w-3.5 h-3.5"></i>
                      <span>Analytics</span>
                    <% end %>
                  </div>
                </div>

                <!-- Timeline bar -->
                <div class="mt-3">
                  <div class="timeline-bar h-1.5 bg-gray-100 rounded-full overflow-hidden flex" data-restaurant-id="<%= restaurant.id %>"></div>
                  <div class="flex justify-between text-[9px] text-gray-300 mt-0.5 px-0.5">
                    <span>00</span><span>06</span><span>12</span><span>18</span><span>now</span>
                  </div>
                </div>
              </div>
            <% end %>
          <% else %>
            <div class="bg-white rounded-xl border shadow-sm p-8 text-center">
              <div class="text-gray-400 mb-4">
                <i data-lucide="store" class="w-12 h-12 mx-auto"></i>
              </div>
              <h3 class="text-lg font-semibold text-gray-900 mb-2"><%= t('dashboard.restaurants_tab.no_restaurants_title') %></h3>
              <p class="text-gray-600 mb-4"><%= t('dashboard.restaurants_tab.no_restaurants_message') %></p>
              <button onclick="window.location.href='/onboarding'" class="inline-flex items-center px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors">
                <i data-lucide="plus" class="w-4 h-4 mr-2"></i>
                <%= t('dashboard.restaurants_tab.add_first_restaurant') %>
              </button>
            </div>
          <% end %>
        </div>

        <!-- Out of Stock Tab -->
        <div id="outofstock-tab" class="tab-content hidden space-y-4">
          <div class="bg-white rounded-xl border shadow-sm">
            <div class="p-6 border-b">
              <h3 class="text-lg font-semibold flex items-center gap-2">
                <i data-lucide="package-x" class="w-5 h-5"></i>
                Out of Stock Items
                <% if @out_of_stock_items.any? %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">
                    <%= @out_of_stock_items.count %>
                  </span>
                <% end %>
              </h3>
              <p class="text-gray-600 text-sm mt-1">Menu items currently unavailable across all restaurants</p>
            </div>
            <div class="p-6">
              <% if @out_of_stock_items.any? %>
                <div class="space-y-3">
                  <% @out_of_stock_items.each do |item| %>
                    <% duration = item.out_of_stock_duration %>
                    <% hours = duration ? (duration / 3600).floor : 0 %>
                    <% minutes = duration ? ((duration % 3600) / 60).floor : 0 %>
                    <% days = hours / 24 %>
                    <% hours = hours % 24 %>
                    <% if days >= 7 %>
                      <% bg_cls, border_cls, icon_cls, badge_cls = 'bg-red-50', 'border-red-200', 'bg-red-100 text-red-600', 'bg-red-600' %>
                    <% elsif days >= 1 %>
                      <% bg_cls, border_cls, icon_cls, badge_cls = 'bg-orange-50', 'border-orange-200', 'bg-orange-100 text-orange-600', 'bg-orange-600' %>
                    <% else %>
                      <% bg_cls, border_cls, icon_cls, badge_cls = 'bg-yellow-50', 'border-yellow-200', 'bg-yellow-100 text-yellow-600', 'bg-yellow-600' %>
                    <% end %>
                    <div class="border rounded-lg p-4 <%= bg_cls %> <%= border_cls %>">
                      <div class="flex items-start gap-3">
                        <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 <%= icon_cls %>">
                          <i data-lucide="x-circle" class="w-4 h-4"></i>
                        </div>
                        <div class="flex-1 min-w-0">
                          <h4 class="font-semibold text-gray-900 truncate"><%= item.name %></h4>
                          <p class="text-sm text-gray-600"><%= item.restaurant.name %> · <%= item.category_name %></p>
                          <div class="flex items-center gap-2 mt-1.5">
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium text-white <%= badge_cls %>">Out of Stock</span>
                            <div class="flex items-center gap-1 text-xs text-gray-500">
                              <i data-lucide="clock" class="w-3 h-3"></i>
                              <span class="oos-timer" data-since="<%= item.status_changed_at&.iso8601 %>">
                                <%= days > 0 ? "#{days}d " : '' %><%= hours %>h <%= minutes %>m
                              </span>
                            </div>
                            <% if item.price_cents %>
                              <span class="text-xs text-gray-500">Rp <%= item.price_cents.to_s.reverse.gsub(/(\d{3})(?=\d)/, '\\1.').reverse %></span>
                            <% end %>
                          </div>
                        </div>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <div class="text-center py-8 text-gray-500">
                  <i data-lucide="check-circle" class="w-12 h-12 mx-auto mb-2 text-green-500"></i>
                  <p class="font-medium">All menu items available</p>
                  <p class="text-sm mt-1">No out-of-stock items detected</p>
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <!-- Reviews Tab -->
        <div id="reviews-tab" class="tab-content hidden space-y-4">
          <div class="bg-white rounded-xl border shadow-sm">
            <div class="p-6 border-b">
              <h3 class="text-lg font-semibold flex items-center gap-2">
                <i data-lucide="star" class="w-5 h-5"></i>
                Recent Reviews
              </h3>
              <p class="text-gray-600 text-sm mt-1">Monitor and respond to customer feedback</p>
            </div>
            <div class="divide-y">
              <!-- Review 1 -->
              <div class="p-6">
                <div class="flex items-start justify-between">
                  <div class="flex-1">
                    <div class="flex items-center gap-2 mb-2">
                      <div class="flex items-center">
                        <i data-lucide="star" class="w-4 h-4 fill-yellow-400 text-yellow-400"></i>
                        <i data-lucide="star" class="w-4 h-4 fill-yellow-400 text-yellow-400"></i>
                        <i data-lucide="star" class="w-4 h-4 fill-yellow-400 text-yellow-400"></i>
                        <i data-lucide="star" class="w-4 h-4 fill-yellow-400 text-yellow-400"></i>
                        <i data-lucide="star" class="w-4 h-4 text-gray-300"></i>
                      </div>
                      <span class="font-semibold">4.0</span>
                      <span class="text-gray-500">•</span>
                      <span class="text-sm text-gray-500">2 hours ago</span>
                    </div>
                    <p class="text-gray-900 mb-2">"Food was great but delivery took longer than expected. Will order again!"</p>
                    <p class="text-sm text-gray-500">Platform: GoJek</p>
                  </div>
                  <button class="ml-4 inline-flex items-center px-3 py-2 text-sm font-medium text-green-700 bg-green-100 hover:bg-green-200 rounded-md transition-colors">
                    Reply
                  </button>
                </div>
              </div>

              <!-- Review 2 -->
              <div class="p-6">
                <div class="flex items-start justify-between">
                  <div class="flex-1">
                    <div class="flex items-center gap-2 mb-2">
                      <div class="flex items-center">
                        <i data-lucide="star" class="w-4 h-4 fill-yellow-400 text-yellow-400"></i>
                        <i data-lucide="star" class="w-4 h-4 fill-yellow-400 text-yellow-400"></i>
                        <i data-lucide="star" class="w-4 h-4 text-gray-300"></i>
                        <i data-lucide="star" class="w-4 h-4 text-gray-300"></i>
                        <i data-lucide="star" class="w-4 h-4 text-gray-300"></i>
                      </div>
                      <span class="font-semibold">2.0</span>
                      <span class="text-gray-500">•</span>
                      <span class="text-sm text-gray-500">4 hours ago</span>
                    </div>
                    <p class="text-gray-900 mb-2">"Food was cold when it arrived. Not satisfied with the service."</p>
                    <p class="text-sm text-gray-500">Platform: Grab</p>
                  </div>
                  <button class="ml-4 inline-flex items-center px-3 py-2 text-sm font-medium text-red-700 bg-red-100 hover:bg-red-200 rounded-md transition-colors">
                    <i data-lucide="alert-triangle" class="w-4 h-4 mr-1"></i>
                    Urgent Reply
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Settings Tab -->
        <div id="settings-tab" class="tab-content hidden space-y-4">
          <div class="bg-white rounded-xl border shadow-sm">
            <div class="p-6 border-b">
              <h3 class="text-lg font-semibold flex items-center gap-2">
                <i data-lucide="settings" class="w-5 h-5"></i>
                Notification Preferences
              </h3>
              <p class="text-gray-600 text-sm mt-1">Configure how you want to receive alerts and updates</p>
            </div>
            <div class="p-6 space-y-6">
              <div class="space-y-4">
                <h4 class="font-medium">Alert Types</h4>
                <div class="space-y-3">
                  <div class="flex items-center justify-between">
                    <label class="text-sm font-medium">Stock alerts</label>
                    <label class="relative inline-flex items-center cursor-pointer">
                      <input type="checkbox" checked class="sr-only peer">
                      <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-green-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-green-600"></div>
                    </label>
                  </div>
                  <div class="flex items-center justify-between">
                    <label class="text-sm font-medium">Review alerts</label>
                    <label class="relative inline-flex items-center cursor-pointer">
                      <input type="checkbox" checked class="sr-only peer">
                      <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-green-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-green-600"></div>
                    </label>
                  </div>
                  <div class="flex items-center justify-between">
                    <label class="text-sm font-medium">Order alerts</label>
                    <label class="relative inline-flex items-center cursor-pointer">
                      <input type="checkbox" class="sr-only peer">
                      <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-green-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-green-600"></div>
                    </label>
                  </div>
                  <div class="flex items-center justify-between">
                    <label class="text-sm font-medium">System alerts</label>
                    <label class="relative inline-flex items-center cursor-pointer">
                      <input type="checkbox" checked class="sr-only peer">
                      <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-green-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-green-600"></div>
                    </label>
                  </div>
                </div>
              </div>

              <div class="space-y-4">
                <h4 class="font-medium">Delivery Methods</h4>
                <div class="space-y-3">
                  <div class="flex items-center justify-between">
                    <label class="text-sm font-medium">Email notifications</label>
                    <label class="relative inline-flex items-center cursor-pointer">
                      <input type="checkbox" checked class="sr-only peer">
                      <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-green-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-green-600"></div>
                    </label>
                  </div>
                  <div class="flex items-center justify-between">
                    <label class="text-sm font-medium">Push notifications</label>
                    <label class="relative inline-flex items-center cursor-pointer">
                      <input type="checkbox" class="sr-only peer">
                      <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-green-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-green-600"></div>
                    </label>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Restaurant Management Section -->
          <div class="bg-white rounded-xl border shadow-sm">
            <div class="p-6 border-b">
              <h3 class="text-lg font-semibold flex items-center gap-2">
                <i data-lucide="store" class="w-5 h-5"></i>
                Restaurant Management
              </h3>
              <p class="text-gray-600 text-sm mt-1">Manage your restaurants and notification contacts</p>
            </div>
            <div class="p-6">
              <div class="space-y-4">
                <% @restaurants.each do |restaurant| %>
                  <div class="border rounded-lg p-4 <%= restaurant.is_active ? 'bg-white' : 'bg-gray-50 opacity-60' %>" data-restaurant-id="<%= restaurant.id %>">
                    <div class="flex items-start justify-between">
                      <div class="flex items-center gap-3 flex-1">
                        <% if restaurant.image_url.present? %>
                          <img src="<%= restaurant.image_url %>" alt="<%= restaurant.name %>" class="w-12 h-12 rounded-lg object-cover flex-shrink-0" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                          <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-gray-200 to-gray-300 flex items-center justify-center flex-shrink-0" style="display: none;">
                            <i data-lucide="store" class="w-6 h-6 text-gray-500"></i>
                          </div>
                        <% else %>
                          <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-gray-200 to-gray-300 flex items-center justify-center flex-shrink-0">
                            <i data-lucide="store" class="w-6 h-6 text-gray-500"></i>
                          </div>
                        <% end %>
                        <div class="flex-1">
                          <div class="flex items-center gap-2">
                            <h4 class="font-medium <%= restaurant.is_active ? 'text-gray-900' : 'text-gray-500' %>">
                              <%= restaurant.name %>
                            </h4>
                          <span class="px-2 py-0.5 text-xs font-medium rounded <%= restaurant.platform == 'grab' ? 'bg-green-100 text-green-700' : 'bg-blue-100 text-blue-700' %>">
                            <%= restaurant.platform_name %>
                          </span>
                          <% unless restaurant.is_active %>
                            <span class="px-2 py-0.5 text-xs font-medium rounded bg-gray-200 text-gray-600">
                              Inactive
                            </span>
                          <% end %>
                        </div>
                        <p class="text-sm text-gray-600 mt-1"><%= restaurant.address %></p>
                        <div class="mt-2 flex flex-wrap gap-2">
                          <% if restaurant.all_whatsapp_contacts.any? %>
                            <span class="text-xs text-gray-600">
                              <i data-lucide="phone" class="w-3 h-3 inline"></i>
                              <%= restaurant.all_whatsapp_contacts.count %> WhatsApp
                            </span>
                          <% end %>
                          <% if restaurant.all_telegram_contacts.any? %>
                            <span class="text-xs text-gray-600">
                              <i data-lucide="message-circle" class="w-3 h-3 inline"></i>
                              <%= restaurant.all_telegram_contacts.count %> Telegram
                            </span>
                          <% end %>
                          <% if restaurant.all_email_contacts.any? %>
                            <span class="text-xs text-gray-600">
                              <i data-lucide="mail" class="w-3 h-3 inline"></i>
                              <%= restaurant.all_email_contacts.count %> Email
                            </span>
                          <% end %>
                        </div>
                        </div>
                      </div>
                      <div class="flex items-center gap-2 ml-4">
                        <button onclick="editRestaurant(<%= restaurant.id %>)" class="px-3 py-2 bg-gradient-to-r from-green-600 to-emerald-700 hover:from-green-700 hover:to-emerald-800 text-white rounded-lg transition-all shadow-sm hover:shadow flex items-center gap-1.5" title="Edit contacts">
                          <i data-lucide="edit-2" class="w-4 h-4"></i>
                        </button>
                        <button onclick="toggleRestaurantActive(<%= restaurant.id %>, <%= restaurant.is_active %>)" class="px-3 py-2 bg-gradient-to-r <%= restaurant.is_active ? 'from-orange-500 to-amber-600 hover:from-orange-600 hover:to-amber-700' : 'from-green-500 to-emerald-600 hover:from-green-600 hover:to-emerald-700' %> text-white rounded-lg transition-all shadow-sm hover:shadow flex items-center gap-1.5" title="<%= restaurant.is_active ? 'Pause monitoring' : 'Activate monitoring' %>">
                          <i data-lucide="<%= restaurant.is_active ? 'pause-circle' : 'play-circle' %>" class="w-4 h-4"></i>
                        </button>
                        <button onclick="deleteRestaurant(<%= restaurant.id %>)" class="px-3 py-2 bg-gradient-to-r from-red-600 to-rose-700 hover:from-red-700 hover:to-rose-800 text-white rounded-lg transition-all shadow-sm hover:shadow flex items-center gap-1.5" title="Delete">
                          <i data-lucide="trash-2" class="w-4 h-4"></i>
                        </button>
                      </div>
                    </div>
                  </div>
                <% end %>

                <% if @restaurants.empty? %>
                  <div class="text-center py-8 text-gray-500">
                    <i data-lucide="store" class="w-12 h-12 mx-auto mb-2 text-gray-300"></i>
                    <p>No restaurants yet</p>
                    <a href="/onboarding" class="text-green-600 hover:underline text-sm mt-2 inline-block">Add your first restaurant</a>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Footer -->
      <div class="text-center text-sm text-gray-500">
        <%= t('dashboard.footer.last_updated') %> <span id="lastUpdate">-</span>
      </div>
    </div>
  </div>

  <!-- Custom Confirm Dialog Modal -->
  <div id="confirmDialog" class="fixed inset-0 bg-gray-900 bg-opacity-50 hidden items-center justify-center z-50" style="display: none;">
    <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full mx-4 overflow-hidden">
      <div class="p-6">
        <div class="flex items-start gap-4">
          <div id="confirmIcon" class="flex-shrink-0 w-12 h-12 rounded-full bg-red-100 flex items-center justify-center">
            <i data-lucide="log-out" class="w-6 h-6 text-red-600"></i>
          </div>
          <div class="flex-1">
            <h3 id="confirmTitle" class="text-lg font-semibold text-gray-900 mb-1">Confirm Action</h3>
            <p id="confirmMessage" class="text-sm text-gray-600">Are you sure you want to proceed?</p>
          </div>
        </div>
      </div>
      <div class="flex gap-3 px-6 pb-6">
        <button id="confirmCancel" class="flex-1 px-4 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium rounded-lg transition-colors">
          Cancel
        </button>
        <button id="confirmOk" class="flex-1 px-4 py-2.5 bg-red-600 hover:bg-red-700 text-white font-medium rounded-lg transition-colors">
          Confirm
        </button>
      </div>
    </div>
  </div>

  <!-- Edit Contacts Modal -->
  <div id="editContactsModal" class="fixed inset-0 bg-gray-900 bg-opacity-50 hidden items-center justify-center z-50" style="display: none;">
    <div class="bg-white rounded-2xl shadow-2xl max-w-2xl w-full mx-4 overflow-hidden">
      <div class="bg-gradient-to-r from-green-600 to-emerald-700 p-6">
        <div class="flex items-center justify-between">
          <h3 class="text-xl font-semibold text-white">Edit Notification Contacts</h3>
          <button onclick="closeEditContactsModal()" class="text-white hover:bg-white hover:bg-opacity-20 rounded-lg p-2 transition-colors">
            <i data-lucide="x" class="w-5 h-5"></i>
          </button>
        </div>
        <p class="text-green-100 text-sm mt-1" id="editModalRestaurantName">Restaurant Name</p>
      </div>

      <div class="p-6 max-h-96 overflow-y-auto">
        <!-- WhatsApp Contacts -->
        <div class="mb-6">
          <label class="block text-sm font-medium text-gray-700 mb-2">
            <i data-lucide="phone" class="w-4 h-4 inline mr-1"></i>
            WhatsApp Numbers
          </label>
          <div id="whatsappContactsList" class="space-y-2 mb-2">
            <!-- Dynamic list of WhatsApp contacts -->
          </div>
          <button onclick="addContactField('whatsapp')" class="text-sm text-green-600 hover:text-green-700 font-medium">
            + Add WhatsApp Number
          </button>
        </div>

        <!-- Telegram Contacts -->
        <div class="mb-6">
          <label class="block text-sm font-medium text-gray-700 mb-2">
            <i data-lucide="message-circle" class="w-4 h-4 inline mr-1"></i>
            Telegram Usernames
          </label>
          <div id="telegramContactsList" class="space-y-2 mb-2">
            <!-- Dynamic list of Telegram contacts -->
          </div>
          <button onclick="addContactField('telegram')" class="text-sm text-green-600 hover:text-green-700 font-medium">
            + Add Telegram Username
          </button>
        </div>

        <!-- Email Contacts -->
        <div class="mb-6">
          <label class="block text-sm font-medium text-gray-700 mb-2">
            <i data-lucide="mail" class="w-4 h-4 inline mr-1"></i>
            Email Addresses
          </label>
          <div id="emailContactsList" class="space-y-2 mb-2">
            <!-- Dynamic list of Email contacts -->
          </div>
          <button onclick="addContactField('email')" class="text-sm text-green-600 hover:text-green-700 font-medium">
            + Add Email Address
          </button>
        </div>
      </div>

      <div class="flex gap-3 px-6 pb-6 border-t pt-4">
        <button onclick="closeEditContactsModal()" class="flex-1 px-4 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium rounded-lg transition-colors">
          Cancel
        </button>
        <button onclick="saveContactsChanges()" class="flex-1 px-4 py-2.5 bg-gradient-to-r from-green-600 to-emerald-700 hover:from-green-700 hover:to-emerald-800 text-white font-medium rounded-lg transition-colors">
          Save Changes
        </button>
      </div>
    </div>
  </div>

  <script>
    console.log('Dashboard script loaded');
    
    function testLogout() {
      console.log('testLogout called!');
      setTimeout(function() {
        showLogoutModal();
      }, 100);
    }
    
    function showLogoutModal() {
      console.log('showLogoutModal called');
      const modal = document.getElementById('logoutModal');
      const modalContent = document.getElementById('modalContent');
      
      if (!modal || !modalContent) {
        console.error('Modal elements not found!');
        return;
      }
      
      modal.classList.remove('hidden');
      modalContent.style.transform = 'scale(0.9)';
      modalContent.style.opacity = '0';
      
      // Re-initialize lucide icons in modal
      lucide.createIcons();
      
      // Animate in
      setTimeout(() => {
        modalContent.style.transform = 'scale(1)';
        modalContent.style.opacity = '1';
      }, 10);
    }

    function hideLogoutModal() {
      console.log('hideLogoutModal called');
      const modal = document.getElementById('logoutModal');
      const modalContent = document.getElementById('modalContent');
      
      modalContent.style.transform = 'scale(0.9)';
      modalContent.style.opacity = '0';
      
      setTimeout(() => {
        modal.classList.add('hidden');
      }, 150);
    }

    function performLogout() {
      console.log('performLogout called');
      // Create and submit logout form
      const form = document.createElement('form');
      form.method = 'POST';
      form.action = '/logout';
      
      // Add CSRF token
      const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');
      if (csrfToken) {
        const csrfInput = document.createElement('input');
        csrfInput.type = 'hidden';
        csrfInput.name = 'authenticity_token';
        csrfInput.value = csrfToken;
        form.appendChild(csrfInput);
      }
      
      // Add method override for DELETE
      const methodInput = document.createElement('input');
      methodInput.type = 'hidden';
      methodInput.name = '_method';
      methodInput.value = 'delete';
      form.appendChild(methodInput);
      
      document.body.appendChild(form);
      form.submit();
    }
    
    lucide.createIcons();

    // Mock data
    let restaurants = [
      { id: 1, name: 'Nasi Padang Express', platform: 'gojek', status: 'online', orders: 45, revenue: 1250000, rating: 4.8, reviews: 234 },
      { id: 2, name: 'Burger Corner', platform: 'grab', status: 'offline', orders: 23, revenue: 890000, rating: 4.5, reviews: 156 },
      { id: 3, name: 'Sushi Delight', platform: 'foodpanda', status: 'busy', orders: 67, revenue: 2100000, rating: 4.9, reviews: 445 }
    ];

    // Tab functionality
    function showTab(tabName) {
      // Hide all tabs
      document.querySelectorAll('.tab-content').forEach(tab => {
        tab.classList.add('hidden');
      });

      // Show selected tab
      document.getElementById(tabName + '-tab').classList.remove('hidden');

      // Update tab buttons
      document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.classList.remove('bg-white', 'text-gray-900', 'shadow-sm');
        btn.classList.add('text-gray-500', 'hover:text-gray-700');
      });

      document.querySelector(`[data-tab="${tabName}"]`).classList.add('bg-white', 'text-gray-900', 'shadow-sm');
      document.querySelector(`[data-tab="${tabName}"]`).classList.remove('text-gray-500', 'hover:text-gray-700');
    }

    // Tab event listeners
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        const tabName = this.getAttribute('data-tab');
        showTab(tabName);
      });
    });

    // Toggle restaurant status
    document.querySelectorAll('.toggle-status-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        const restaurantId = parseInt(this.getAttribute('data-restaurant'));
        const currentStatus = this.getAttribute('data-status');
        const newStatus = currentStatus === 'online' ? 'offline' : 'online';
        
        // Update restaurant data
        const restaurant = restaurants.find(r => r.id === restaurantId);
        if (restaurant) {
          restaurant.status = newStatus;
        }

        // Update UI
        updateRestaurantStatus(restaurantId, newStatus);
        updateOverviewCards();
      });
    });

    function updateRestaurantStatus(id, status) {
      const statusElement = document.getElementById(`status-${id}`);
      const btn = document.querySelector(`[data-restaurant="${id}"]`);
      
      if (status === 'online') {
        statusElement.innerHTML = `
          <div class="w-3 h-3 rounded-full bg-green-500 animate-pulse"></div>
          <span class="text-sm font-medium text-green-700">Online</span>
        `;
        btn.className = 'toggle-status-btn inline-flex items-center px-3 py-2 border border-red-200 text-red-600 hover:bg-red-50 rounded-md text-sm font-medium transition-colors';
        btn.innerHTML = '<i data-lucide="wifi-off" class="w-4 h-4 mr-2"></i>Go Offline';
        btn.setAttribute('data-status', 'online');
      } else {
        statusElement.innerHTML = `
          <div class="w-3 h-3 rounded-full bg-red-500 animate-pulse"></div>
          <span class="text-sm font-medium text-red-700">Offline</span>
        `;
        btn.className = 'toggle-status-btn inline-flex items-center px-3 py-2 border border-green-200 text-green-600 hover:bg-green-50 rounded-md text-sm font-medium transition-colors';
        btn.innerHTML = '<i data-lucide="wifi" class="w-4 h-4 mr-2"></i>Go Online';
        btn.setAttribute('data-status', 'offline');
      }
      
      lucide.createIcons();
    }

    function updateOverviewCards() {
      const totalRevenue = restaurants.reduce((sum, r) => sum + r.revenue, 0);
      const totalOrders = restaurants.reduce((sum, r) => sum + r.orders, 0);
      const onlineRestaurants = restaurants.filter(r => r.status === 'online').length;
      const avgRating = restaurants.reduce((sum, r) => sum + r.rating, 0) / restaurants.length;

      document.getElementById('totalRevenue').textContent = formatCurrency(totalRevenue);
      document.getElementById('totalOrders').textContent = totalOrders;
      document.getElementById('onlineStores').textContent = `${onlineRestaurants}/${restaurants.length}`;
      document.getElementById('operationalPercentage').textContent = `${Math.round((onlineRestaurants / restaurants.length) * 100)}% operational`;
      document.getElementById('avgRating').textContent = avgRating.toFixed(1);
    }

    function formatCurrency(amount) {
      return 'Rp ' + amount.toLocaleString('id-ID');
    }

    // Dismiss alerts
    document.querySelectorAll('.dismiss-alert').forEach(btn => {
      btn.addEventListener('click', function() {
        this.closest('.alert-item').style.opacity = '0';
        setTimeout(() => {
          this.closest('.alert-item').remove();
        }, 300);
      });
    });

    // Refresh functionality
    document.getElementById('refreshBtn').addEventListener('click', function() {
      const icon = this.querySelector('i');
      icon.classList.add('animate-spin');
      
      // Simulate refresh
      setTimeout(() => {
        icon.classList.remove('animate-spin');
        updateLastUpdate();
        // Simulate small changes to data
        restaurants.forEach(r => {
          r.orders += Math.floor(Math.random() * 3);
          r.revenue += Math.floor(Math.random() * 50000);
        });
        updateOverviewCards();
      }, 1000);
    });

    function updateLastUpdate() {
      const now = new Date();
      document.getElementById('lastUpdate').textContent = now.toLocaleTimeString();
    }

    // Initialize
    updateOverviewCards();
    updateLastUpdate();
    showTab('restaurants');

    // Update time every minute
    setInterval(updateLastUpdate, 60000);

    // Add Restaurant button handler
    document.getElementById('addRestaurantBtn').addEventListener('click', function() {
      console.log('Add Restaurant button clicked');
      window.location.href = '/onboarding';
    });

    // Initialize modal buttons
    document.addEventListener('DOMContentLoaded', function() {
      const cancelBtn = document.getElementById('cancelLogout');
      const confirmBtn = document.getElementById('confirmLogout');
      const modal = document.getElementById('logoutModal');
      
      if (cancelBtn) {
        cancelBtn.addEventListener('click', hideLogoutModal);
      }
      
      if (confirmBtn) {
        confirmBtn.addEventListener('click', function() {
          hideLogoutModal();
          setTimeout(performLogout, 150);
        });
      }
      
      if (modal) {
        modal.addEventListener('click', function(e) {
          if (e.target === this) {
            hideLogoutModal();
          }
        });
      }
      
      // Close modal with Escape key
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) {
          hideLogoutModal();
        }
      });
    });

    function initializeLogoutModal() {
      console.log('Initializing logout modal...');
      
      // Check if elements exist
      const logoutBtn = document.getElementById('logoutBtn');
      const cancelBtn = document.getElementById('cancelLogout');
      const confirmBtn = document.getElementById('confirmLogout');
      const modal = document.getElementById('logoutModal');
      
      console.log('Elements found:', {
        logoutBtn: !!logoutBtn,
        cancelBtn: !!cancelBtn,
        confirmBtn: !!confirmBtn,
        modal: !!modal
      });
      
      console.log('logoutBtn element:', logoutBtn);
      console.log('modal element:', modal);
      
      if (!logoutBtn) {
        console.error('logoutBtn not found!');
        return;
      }
      
      if (!cancelBtn || !confirmBtn || !modal) {
        console.error('Some modal elements not found!', {
          cancelBtn: !!cancelBtn,
          confirmBtn: !!confirmBtn,
          modal: !!modal
        });
        return;
      }

      // Logout functions
      function showLogoutModal() {
        console.log('showLogoutModal called');
        const modal = document.getElementById('logoutModal');
        const modalContent = document.getElementById('modalContent');
        
        modal.classList.remove('hidden');
        modalContent.style.transform = 'scale(0.9)';
        modalContent.style.opacity = '0';
        
        // Re-initialize lucide icons in modal
        lucide.createIcons();
        
        // Animate in
        setTimeout(() => {
          modalContent.style.transform = 'scale(1)';
          modalContent.style.opacity = '1';
        }, 10);
      }

      function hideLogoutModal() {
        console.log('hideLogoutModal called');
        const modal = document.getElementById('logoutModal');
        const modalContent = document.getElementById('modalContent');
        
        modalContent.style.transform = 'scale(0.9)';
        modalContent.style.opacity = '0';
        
        setTimeout(() => {
          modal.classList.add('hidden');
        }, 150);
      }

      function performLogout() {
        console.log('performLogout called');
        // Create and submit logout form
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '/logout';
        
        // Add CSRF token
        const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');
        if (csrfToken) {
          const csrfInput = document.createElement('input');
          csrfInput.type = 'hidden';
          csrfInput.name = 'authenticity_token';
          csrfInput.value = csrfToken;
          form.appendChild(csrfInput);
        }
        
        // Add method override for DELETE
        const methodInput = document.createElement('input');
        methodInput.type = 'hidden';
        methodInput.name = '_method';
        methodInput.value = 'delete';
        form.appendChild(methodInput);
        
        document.body.appendChild(form);
        form.submit();
      }

      // Event listeners
      logoutBtn.addEventListener('click', function() {
        console.log('Logout button clicked');
        showLogoutModal();
      });

      // Modal event listeners
      cancelBtn.addEventListener('click', function() {
        console.log('Cancel logout clicked');
        hideLogoutModal();
      });
      
      confirmBtn.addEventListener('click', function() {
        console.log('Confirm logout clicked');
        hideLogoutModal();
        setTimeout(performLogout, 150);
      });

      // Close modal when clicking outside
      modal.addEventListener('click', function(e) {
        if (e.target === this) {
          hideLogoutModal();
        }
      });

      // Close modal with Escape key
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
          hideLogoutModal();
        }
      });
    }

    // Custom Confirm Dialog System
    function showConfirmDialog(title, message, iconName, iconBg, buttonText, buttonColor, callback) {
      console.log('showConfirmDialog called with:', { title, message, iconName, iconBg, buttonText, buttonColor });
      const dialog = document.getElementById('confirmDialog');
      const icon = document.getElementById('confirmIcon');
      const titleElement = document.getElementById('confirmTitle');
      const messageElement = document.getElementById('confirmMessage');
      const okButton = document.getElementById('confirmOk');
      const cancelButton = document.getElementById('confirmCancel');

      if (!dialog || !icon || !titleElement || !messageElement || !okButton || !cancelButton) {
        console.error('Missing dialog elements:', { dialog, icon, titleElement, messageElement, okButton, cancelButton });
        return;
      }

      titleElement.textContent = title;
      messageElement.textContent = message;
      icon.className = `flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center ${iconBg}`;

      // Replace icon completely
      icon.innerHTML = `<i data-lucide="${iconName}" class="w-6 h-6"></i>`;

      okButton.textContent = buttonText;
      okButton.className = `flex-1 px-4 py-2.5 ${buttonColor} text-white font-medium rounded-lg transition-colors`;

      // Reinitialize lucide icons for the new icon
      if (window.lucide) {
        lucide.createIcons();
      }

      dialog.style.display = 'flex';
      dialog.classList.remove('hidden');

      function closeDialog() {
        dialog.style.display = 'none';
        dialog.classList.add('hidden');
        okButton.onclick = null;
        cancelButton.onclick = null;
      }

      okButton.onclick = function() {
        closeDialog();
        callback();
      };

      cancelButton.onclick = closeDialog;

      dialog.onclick = function(e) {
        if (e.target === this) {
          closeDialog();
        }
      };
    }

    // Restaurant Management Functions
    let currentEditingRestaurantId = null;

    function toggleRestaurantActive(restaurantId, currentlyActive) {
      console.log('toggleRestaurantActive called:', restaurantId, currentlyActive);
      const title = currentlyActive ? 'Pause Monitoring' : 'Activate Monitoring';
      const message = currentlyActive
        ? 'Are you sure you want to pause monitoring for this restaurant? It will stop receiving status checks.'
        : 'Are you sure you want to activate monitoring for this restaurant?';
      const iconName = currentlyActive ? 'pause-circle' : 'play-circle';
      const iconBg = currentlyActive ? 'bg-orange-100' : 'bg-green-100';
      const buttonText = currentlyActive ? 'Pause' : 'Activate';
      const buttonColor = currentlyActive ? 'bg-orange-600 hover:bg-orange-700' : 'bg-green-600 hover:bg-green-700';

      showConfirmDialog(title, message, iconName, iconBg, buttonText, buttonColor, function() {
        console.log('Confirm dialog callback executed');
        const url = `/restaurants/${restaurantId}/toggle_active`;
        const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');

        console.log('Fetching:', url);
        console.log('CSRF Token:', csrfToken);
        console.log('Headers:', {
          'Content-Type': 'application/json',
          'X-CSRF-Token': csrfToken,
          'Accept': 'application/json'
        });

        fetch(url, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': csrfToken,
            'Accept': 'application/json'
          },
          credentials: 'same-origin'
        })
        .then(response => {
          console.log('Response status:', response.status);
          console.log('Response headers:', response.headers);
          console.log('Response content-type:', response.headers.get('content-type'));

          if (!response.ok) {
            return response.text().then(text => {
              console.error('Response error text:', text);
              throw new Error(`HTTP ${response.status}: ${text.substring(0, 200)}`);
            });
          }

          return response.json();
        })
        .then(data => {
          console.log('Response data:', data);
          if (data.success) {
            showToast(data.message || 'Restaurant status updated', 'success');

            // Update the restaurant card UI without reload
            updateRestaurantCardStatus(restaurantId, data.is_active);

            // Stay on Settings tab and scroll to restaurant list
            const settingsButton = document.querySelector('button[data-tab="settings"]');
            if (settingsButton) {
              settingsButton.click();
              setTimeout(() => {
                const restaurantCard = document.querySelector(`[data-restaurant-id="${restaurantId}"]`);
                if (restaurantCard) {
                  restaurantCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
              }, 200);
            }
          } else {
            showToast('Error: ' + (data.errors || ['Unknown error']).join(', '), 'error');
          }
        })
        .catch(error => {
          console.error('Fetch error:', error);
          showToast('Failed to update restaurant status: ' + error.message, 'error');
        });
      });
    }

    function deleteRestaurant(restaurantId) {
      console.log('deleteRestaurant called:', restaurantId);
      const title = 'Delete Restaurant';
      const message = 'Are you sure you want to delete this restaurant? This action cannot be undone. All data including contacts and status history will be permanently removed.';
      const iconName = 'trash-2';
      const iconBg = 'bg-red-100';
      const buttonText = 'Delete';
      const buttonColor = 'bg-red-600 hover:bg-red-700';

      showConfirmDialog(title, message, iconName, iconBg, buttonText, buttonColor, function() {
        console.log('Delete confirm dialog callback executed');
        const url = `/restaurants/${restaurantId}`;
        const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');

        console.log('DELETE Fetching:', url);
        console.log('CSRF Token:', csrfToken);

        fetch(url, {
          method: 'DELETE',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': csrfToken,
            'Accept': 'application/json'
          },
          credentials: 'same-origin'
        })
        .then(response => {
          console.log('DELETE Response status:', response.status);
          console.log('DELETE Response content-type:', response.headers.get('content-type'));

          if (!response.ok) {
            return response.text().then(text => {
              console.error('DELETE Response error text:', text);
              throw new Error(`HTTP ${response.status}: ${text.substring(0, 200)}`);
            });
          }

          return response.json();
        })
        .then(data => {
          console.log('DELETE Response data:', data);
          if (data.success) {
            // Remove card from UI
            const restaurantCard = document.querySelector(`[data-restaurant-id="${restaurantId}"]`);
            if (restaurantCard) {
              restaurantCard.style.opacity = '0';
              restaurantCard.style.transform = 'scale(0.95)';
              restaurantCard.style.transition = 'all 0.3s ease';
              setTimeout(() => {
                restaurantCard.remove();
                showToast(data.message || 'Restaurant deleted successfully', 'success');
              }, 300);
            }
          } else {
            showToast('Error: ' + (data.errors || ['Unknown error']).join(', '), 'error');
          }
        })
        .catch(error => {
          console.error('DELETE Fetch error:', error);
          showToast('Failed to delete restaurant: ' + error.message, 'error');
        });
      });
    }

    function editRestaurant(restaurantId) {
      console.log('editRestaurant called:', restaurantId);
      currentEditingRestaurantId = restaurantId;

      // Fetch restaurant data
      const restaurantCard = document.querySelector(`[data-restaurant-id="${restaurantId}"]`);
      const restaurantName = restaurantCard.querySelector('h4').textContent.trim();
      console.log('Restaurant name:', restaurantName);

      // Fetch current contacts from server
      const url = `/restaurants/${restaurantId}`;
      const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');

      console.log('GET Fetching restaurant data from:', url);
      console.log('CSRF Token:', csrfToken);

      fetch(url, {
        method: 'GET',
        headers: {
          'Accept': 'application/json',
          'Content-Type': 'application/json',
          'X-CSRF-Token': csrfToken
        },
        credentials: 'same-origin'
      })
        .then(response => {
          console.log('GET Response status:', response.status);
          console.log('GET Response content-type:', response.headers.get('content-type'));

          if (!response.ok) {
            return response.text().then(text => {
              console.error('GET Response error text:', text);
              throw new Error(`HTTP ${response.status}: ${text.substring(0, 200)}`);
            });
          }

          return response.json();
        })
        .then(data => {
          console.log('GET Restaurant data:', data);
          if (data.success) {
            openEditContactsModal(restaurantName, data.restaurant.contacts);
          } else {
            console.error('Failed to fetch restaurant:', data);
            showToast('Failed to load contacts: ' + (data.errors || ['Unknown error']).join(', '), 'error');
            // Still open modal with empty contacts so user can add
            openEditContactsModal(restaurantName, { whatsapp: [], telegram: [], email: [] });
          }
        })
        .catch(error => {
          console.error('GET Error fetching restaurant data:', error);
          showToast('Failed to load contacts: ' + error.message, 'error');
          // Fallback: open modal with empty contacts
          openEditContactsModal(restaurantName, { whatsapp: [], telegram: [], email: [] });
        });
    }

    function openEditContactsModal(restaurantName, contacts) {
      console.log('openEditContactsModal called with:', { restaurantName, contacts });
      const modal = document.getElementById('editContactsModal');
      const nameElement = document.getElementById('editModalRestaurantName');

      nameElement.textContent = restaurantName;

      // Populate WhatsApp contacts
      const whatsappList = document.getElementById('whatsappContactsList');
      whatsappList.innerHTML = '';
      const whatsappContacts = contacts.whatsapp || [];
      console.log('WhatsApp contacts:', whatsappContacts);
      if (whatsappContacts.length === 0) {
        // Add one empty field if no contacts
        addContactToList('whatsapp', '', whatsappList);
      } else {
        whatsappContacts.forEach(contact => {
          addContactToList('whatsapp', contact, whatsappList);
        });
      }

      // Populate Telegram contacts
      const telegramList = document.getElementById('telegramContactsList');
      telegramList.innerHTML = '';
      const telegramContacts = contacts.telegram || [];
      console.log('Telegram contacts:', telegramContacts);
      if (telegramContacts.length === 0) {
        // Add one empty field if no contacts
        addContactToList('telegram', '', telegramList);
      } else {
        telegramContacts.forEach(contact => {
          addContactToList('telegram', contact, telegramList);
        });
      }

      // Populate Email contacts
      const emailList = document.getElementById('emailContactsList');
      emailList.innerHTML = '';
      const emailContacts = contacts.email || [];
      console.log('Email contacts:', emailContacts);
      if (emailContacts.length === 0) {
        // Add one empty field if no contacts
        addContactToList('email', '', emailList);
      } else {
        emailContacts.forEach(contact => {
          addContactToList('email', contact, emailList);
        });
      }

      modal.style.display = 'flex';
      modal.classList.remove('hidden');

      // Reinitialize lucide icons
      if (window.lucide) {
        lucide.createIcons();
      }
    }

    function closeEditContactsModal() {
      const modal = document.getElementById('editContactsModal');
      modal.style.display = 'none';
      modal.classList.add('hidden');
      currentEditingRestaurantId = null;
    }

    function addContactToList(type, value, listElement) {
      const contactDiv = document.createElement('div');
      contactDiv.className = 'flex items-center gap-2';

      const input = document.createElement('input');
      input.type = 'text';
      input.value = value;
      input.className = 'flex-1 px-3 py-2 border rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500';
      input.placeholder = type === 'whatsapp' ? '+62812345678' : type === 'telegram' ? '@username' : 'email@example.com';
      input.dataset.contactType = type;

      const removeBtn = document.createElement('button');
      removeBtn.type = 'button';
      removeBtn.className = 'p-2 text-red-600 hover:bg-red-50 rounded-lg transition-colors';
      removeBtn.innerHTML = '<i data-lucide="x" class="w-4 h-4"></i>';
      removeBtn.onclick = function() {
        contactDiv.remove();
      };

      contactDiv.appendChild(input);
      contactDiv.appendChild(removeBtn);
      listElement.appendChild(contactDiv);

      // Reinitialize lucide icons
      if (window.lucide) {
        lucide.createIcons();
      }
    }

    function addContactField(type) {
      const listId = type + 'ContactsList';
      const listElement = document.getElementById(listId);
      addContactToList(type, '', listElement);
    }

    function saveContactsChanges() {
      if (!currentEditingRestaurantId) return;

      // Collect all contacts
      const whatsappInputs = document.querySelectorAll('#whatsappContactsList input');
      const telegramInputs = document.querySelectorAll('#telegramContactsList input');
      const emailInputs = document.querySelectorAll('#emailContactsList input');

      const contacts = {
        whatsapp: Array.from(whatsappInputs).map(input => input.value.trim()).filter(v => v),
        telegram: Array.from(telegramInputs).map(input => input.value.trim()).filter(v => v),
        email: Array.from(emailInputs).map(input => input.value.trim()).filter(v => v),
        replace: true // Replace all contacts
      };

      // Send to server
      fetch(`/restaurants/${currentEditingRestaurantId}`, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.getAttribute('content')
        },
        body: JSON.stringify({ contacts })
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          closeEditContactsModal();
          showToast('Contacts updated successfully', 'success');

          // Update contact counts in the card without reload
          updateRestaurantContactCounts(currentEditingRestaurantId, data.restaurant.contacts);

          // Stay on Settings tab and scroll to the restaurant
          const settingsButton = document.querySelector('button[data-tab="settings"]');
          if (settingsButton) {
            settingsButton.click();
            setTimeout(() => {
              const restaurantCard = document.querySelector(`[data-restaurant-id="${currentEditingRestaurantId}"]`);
              if (restaurantCard) {
                restaurantCard.scrollIntoView({ behavior: 'smooth', block: 'center' });

                // Highlight briefly
                restaurantCard.style.transition = 'all 0.3s ease';
                restaurantCard.style.boxShadow = '0 0 0 3px rgba(34, 197, 94, 0.5)';
                setTimeout(() => {
                  restaurantCard.style.boxShadow = '';
                }, 2000);
              }
            }, 200);
          }
        } else {
          showToast('Error: ' + (data.errors || ['Unknown error']).join(', '), 'error');
        }
      })
      .catch(error => {
        console.error('Error:', error);
        showToast('Failed to update contacts', 'error');
      });
    }

    // Update restaurant contact counts without page reload
    function updateRestaurantContactCounts(restaurantId, contacts) {
      console.log('Updating restaurant contacts:', restaurantId, contacts);
      const restaurantCard = document.querySelector(`[data-restaurant-id="${restaurantId}"]`);

      if (!restaurantCard) {
        console.error('Restaurant card not found:', restaurantId);
        return;
      }

      // Find the contacts display container
      const contactsContainer = restaurantCard.querySelector('.mt-2.flex.flex-wrap.gap-2');

      if (!contactsContainer) {
        console.error('Contacts container not found');
        return;
      }

      // Clear existing contacts display
      contactsContainer.innerHTML = '';

      // Add WhatsApp contacts
      if (contacts.whatsapp && contacts.whatsapp.length > 0) {
        const whatsappSpan = document.createElement('span');
        whatsappSpan.className = 'text-xs text-gray-600';
        whatsappSpan.innerHTML = `<i data-lucide="phone" class="w-3 h-3 inline"></i> ${contacts.whatsapp.length} WhatsApp`;
        contactsContainer.appendChild(whatsappSpan);
      }

      // Add Telegram contacts
      if (contacts.telegram && contacts.telegram.length > 0) {
        const telegramSpan = document.createElement('span');
        telegramSpan.className = 'text-xs text-gray-600';
        telegramSpan.innerHTML = `<i data-lucide="message-circle" class="w-3 h-3 inline"></i> ${contacts.telegram.length} Telegram`;
        contactsContainer.appendChild(telegramSpan);
      }

      // Add Email contacts
      if (contacts.email && contacts.email.length > 0) {
        const emailSpan = document.createElement('span');
        emailSpan.className = 'text-xs text-gray-600';
        emailSpan.innerHTML = `<i data-lucide="mail" class="w-3 h-3 inline"></i> ${contacts.email.length} Email`;
        contactsContainer.appendChild(emailSpan);
      }

      // Reinitialize lucide icons
      if (window.lucide) {
        lucide.createIcons();
      }
    }

    // Update restaurant card status without page reload
    function updateRestaurantCardStatus(restaurantId, isActive) {
      console.log('Updating restaurant card:', restaurantId, 'isActive:', isActive);
      const restaurantCard = document.querySelector(`[data-restaurant-id="${restaurantId}"]`);

      if (!restaurantCard) {
        console.error('Restaurant card not found:', restaurantId);
        return;
      }

      // Update background color
      if (isActive) {
        restaurantCard.classList.remove('bg-gray-50', 'opacity-60');
        restaurantCard.classList.add('bg-white');
      } else {
        restaurantCard.classList.remove('bg-white');
        restaurantCard.classList.add('bg-gray-50', 'opacity-60');
      }

      // Update inactive badge
      const nameContainer = restaurantCard.querySelector('h4').parentElement;
      let inactiveBadge = nameContainer.querySelector('.inactive-badge');

      if (!isActive && !inactiveBadge) {
        // Add inactive badge
        inactiveBadge = document.createElement('span');
        inactiveBadge.className = 'inactive-badge px-2 py-0.5 text-xs font-medium rounded bg-gray-200 text-gray-600';
        inactiveBadge.textContent = 'Inactive';
        nameContainer.appendChild(inactiveBadge);
      } else if (isActive && inactiveBadge) {
        // Remove inactive badge
        inactiveBadge.remove();
      }

      // Update toggle button
      const toggleButton = restaurantCard.querySelector(`button[onclick*="toggleRestaurantActive"]`);
      if (toggleButton) {
        const iconElement = toggleButton.querySelector('i');

        if (isActive) {
          // Change to Pause button
          toggleButton.className = 'px-3 py-2 bg-gradient-to-r from-orange-500 to-amber-600 hover:from-orange-600 hover:to-amber-700 text-white rounded-lg transition-all shadow-sm hover:shadow flex items-center gap-1.5';
          toggleButton.title = 'Pause monitoring';
          if (iconElement) {
            iconElement.setAttribute('data-lucide', 'pause-circle');
          }
        } else {
          // Change to Activate button
          toggleButton.className = 'px-3 py-2 bg-gradient-to-r from-green-500 to-emerald-600 hover:from-green-600 hover:to-emerald-700 text-white rounded-lg transition-all shadow-sm hover:shadow flex items-center gap-1.5';
          toggleButton.title = 'Activate monitoring';
          if (iconElement) {
            iconElement.setAttribute('data-lucide', 'play-circle');
          }
        }

        // Update onclick handler
        toggleButton.setAttribute('onclick', `toggleRestaurantActive(${restaurantId}, ${isActive})`);

        // Reinitialize lucide icons
        if (window.lucide) {
          lucide.createIcons();
        }
      }

      // Move card to appropriate position (inactive cards go to bottom)
      const container = restaurantCard.parentElement;
      const allCards = Array.from(container.querySelectorAll('[data-restaurant-id]'));

      // Remove card temporarily
      restaurantCard.remove();

      // Find correct position
      let insertBefore = null;
      for (const card of allCards) {
        if (card === restaurantCard) continue;

        const cardIsActive = !card.classList.contains('opacity-60');

        if (isActive && !cardIsActive) {
          // Current card is active, insert before first inactive
          insertBefore = card;
          break;
        } else if (!isActive && cardIsActive) {
          // Current card is inactive, keep looking for inactive section
          continue;
        }
      }

      if (insertBefore) {
        container.insertBefore(restaurantCard, insertBefore);
      } else {
        container.appendChild(restaurantCard);
      }

      // Highlight updated card briefly
      restaurantCard.style.transition = 'all 0.3s ease';
      restaurantCard.style.boxShadow = '0 0 0 3px rgba(34, 197, 94, 0.5)';
      setTimeout(() => {
        restaurantCard.style.boxShadow = '';
      }, 2000);
    }

    // Simple toast notification
    function showToast(message, type = 'info') {
      const toast = document.createElement('div');
      const bgColor = type === 'success' ? 'bg-green-600' : type === 'error' ? 'bg-red-600' : 'bg-blue-600';
      toast.className = `fixed bottom-4 right-4 ${bgColor} text-white px-6 py-3 rounded-lg shadow-lg z-50 transition-opacity`;
      toast.textContent = message;
      document.body.appendChild(toast);

      setTimeout(() => {
        toast.style.opacity = '0';
        setTimeout(() => toast.remove(), 300);
      }, 3000);
    }

    // === LIVE STATUS TIMERS ===
    function formatDuration(ms) {
      const totalSec = Math.floor(ms / 1000);
      const hours = Math.floor(totalSec / 3600);
      const minutes = Math.floor((totalSec % 3600) / 60);
      const seconds = totalSec % 60;
      if (hours > 0) return hours + 'h ' + String(minutes).padStart(2,'0') + 'm';
      return minutes + 'm ' + String(seconds).padStart(2,'0') + 's';
    }

    function updateTimers() {
      const now = Date.now();
      document.querySelectorAll('.status-timer, .oos-timer').forEach(el => {
        const since = el.dataset.since;
        if (!since) return;
        const elapsed = now - new Date(since).getTime();
        if (elapsed > 0) el.textContent = formatDuration(elapsed);
      });
    }
    setInterval(updateTimers, 1000);
    updateTimers();

    // === DAILY TIMELINE BARS ===
    function loadTimelines() {
      document.querySelectorAll('.timeline-bar').forEach(async bar => {
        const rid = bar.dataset.restaurantId;
        if (!rid) return;
        try {
          const resp = await fetch('/dashboard/timeline_data?restaurant_id=' + rid);
          if (!resp.ok) return;
          const data = await resp.json();
          bar.innerHTML = '';
          if (!data.segments || data.segments.length === 0) {
            bar.innerHTML = '<div class="h-full w-full bg-gray-200 rounded-full"></div>';
            return;
          }
          data.segments.forEach(seg => {
            const width = Math.max(seg.end_pct - seg.start_pct, 0.5);
            const color = seg.status === 'open' ? 'bg-green-500' :
                          seg.status === 'closed' ? 'bg-red-400' : 'bg-gray-300';
            const div = document.createElement('div');
            div.className = 'h-full ' + color;
            div.style.width = width + '%';
            div.title = seg.status + ' (' + new Date(seg.start).toLocaleTimeString('en',{hour:'2-digit',minute:'2-digit',hour12:false}) + ' - ' + new Date(seg.end).toLocaleTimeString('en',{hour:'2-digit',minute:'2-digit',hour12:false}) + ')';
            bar.appendChild(div);
          });
        } catch(e) { /* ignore */ }
      });
    }
    loadTimelines();
  </script>
</body>
