<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Analytics - <%= @restaurant.name %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
</head>
<body class="min-h-screen bg-gray-50">
  <div class="max-w-2xl mx-auto p-4 md:p-6 space-y-4">

    <!-- Header -->
    <div>
      <a href="<%= dashboard_path %>" class="text-gray-400 hover:text-gray-600 text-xs flex items-center gap-1 mb-2">
        <i data-lucide="arrow-left" class="w-3.5 h-3.5"></i> Back to Dashboard
      </a>
      <h1 class="text-xl font-bold text-gray-900"><%= @restaurant.name %></h1>
      <p class="text-xs text-gray-400"><%= @restaurant.platform_name %></p>
    </div>

    <!-- Current Status -->
    <div id="current-status" class="rounded-xl border-2 p-6 text-center bg-white">
      <div class="text-sm text-gray-400 mb-1">Current Status</div>
      <div id="status-icon" class="text-5xl mb-2">--</div>
      <div id="status-label" class="text-2xl font-bold mb-1">Loading...</div>
      <div id="status-timer" class="text-sm text-gray-500 font-mono"></div>
    </div>

    <!-- Period + Summary -->
    <div class="bg-white rounded-xl border p-4">
      <div class="flex items-center justify-between mb-3">
        <span class="text-sm font-semibold text-gray-900">Uptime</span>
        <div class="bg-gray-100 rounded-lg p-0.5 inline-flex">
          <% %w[7d 30d].each do |p| %>
            <button onclick="loadPeriod('<%= p %>')" id="btn-<%= p %>"
              class="period-btn px-3 py-1 text-xs font-medium rounded-md transition-colors <%= p == @period ? 'bg-white text-gray-900 shadow-sm' : 'text-gray-500' %>">
              <%= p == '7d' ? '7 days' : '30 days' %>
            </button>
          <% end %>
        </div>
      </div>
      <div class="flex items-baseline gap-2 mb-3">
        <span id="period-uptime" class="text-3xl font-bold">--%</span>
        <span id="period-subtitle" class="text-sm text-gray-400"></span>
      </div>
      <!-- Menu summary -->
      <div id="menu-summary" class="text-sm text-gray-400"></div>
    </div>

    <!-- Day rows -->
    <div class="bg-white rounded-xl border divide-y" id="days-container">
      <div class="p-8 text-center text-sm text-gray-300">Loading...</div>
    </div>

  </div>

<script>
lucide.createIcons();
const RID = <%= @restaurant.id %>;
let currentPeriod = '<%= @period || "7d" %>';
const BALI_OFFSET = 8 * 3600000;

function toBali(ts) { return new Date(ts + BALI_OFFSET); }
function pad(n) { return String(n).padStart(2, '0'); }
function fmtTime(d) { return pad(d.getHours()) + ':' + pad(d.getMinutes()); }

function loadPeriod(p) {
  currentPeriod = p;
  document.querySelectorAll('.period-btn').forEach(b => {
    b.classList.remove('bg-white','text-gray-900','shadow-sm');
    b.classList.add('text-gray-500');
  });
  document.getElementById('btn-'+p).classList.add('bg-white','text-gray-900','shadow-sm');
  document.getElementById('btn-'+p).classList.remove('text-gray-500');
  loadData();
}

async function loadData() {
  const resp = await fetch(`/restaurants/${RID}/analytics_data?period=${currentPeriod}`);
  const data = await resp.json();
  if (!data.success) return;

  const m = data.metrics;
  const timeline = data.timeline;

  // Period uptime
  const uptimePct = m.uptime_percentage.toFixed(1);
  const el = document.getElementById('period-uptime');
  el.textContent = uptimePct + '%';
  el.className = 'text-3xl font-bold ' + (uptimePct >= 95 ? 'text-green-600' : uptimePct >= 70 ? 'text-yellow-600' : 'text-red-600');
  document.getElementById('period-subtitle').textContent =
    m.open_checks + ' open / ' + m.closed_checks + ' closed checks · ' + m.anomalies_count + ' anomalies';

  // Group checks by day (Bali time)
  const days = {};
  timeline.forEach(t => {
    const d = toBali(t.ts);
    const key = d.getFullYear() + '-' + pad(d.getMonth()+1) + '-' + pad(d.getDate());
    if (!days[key]) days[key] = [];
    days[key].push({ ...t, bali: d });
  });

  // Current status (from latest check)
  if (timeline.length > 0) {
    const last = timeline[timeline.length - 1];
    updateCurrentStatus(last);
  }

  // Build day rows
  const sortedDays = Object.keys(days).sort().reverse(); // newest first
  buildDayRows(sortedDays, days);

  // Menu
  loadMenuSummary();
}

function updateCurrentStatus(last) {
  const statusEl = document.getElementById('current-status');
  const iconEl = document.getElementById('status-icon');
  const labelEl = document.getElementById('status-label');
  const timerEl = document.getElementById('status-timer');

  if (last.s === 1) {
    statusEl.className = 'rounded-xl border-2 border-green-200 bg-green-50 p-6 text-center';
    iconEl.textContent = '🟢';
    labelEl.textContent = 'OPEN';
    labelEl.className = 'text-2xl font-bold text-green-700 mb-1';
  } else if (last.s === 0) {
    statusEl.className = 'rounded-xl border-2 border-red-200 bg-red-50 p-6 text-center';
    iconEl.textContent = '🔴';
    labelEl.textContent = 'CLOSED';
    labelEl.className = 'text-2xl font-bold text-red-700 mb-1';
  } else {
    statusEl.className = 'rounded-xl border-2 border-gray-200 bg-gray-50 p-6 text-center';
    iconEl.textContent = '⚪';
    labelEl.textContent = 'UNKNOWN';
    labelEl.className = 'text-2xl font-bold text-gray-500 mb-1';
  }

  // Start ticking timer
  const since = last.ts;
  function tick() {
    const elapsed = Date.now() - since;
    const h = Math.floor(elapsed / 3600000);
    const m = Math.floor((elapsed % 3600000) / 60000);
    const s = Math.floor((elapsed % 60000) / 1000);
    timerEl.textContent = (h > 0 ? h + 'h ' : '') + pad(m) + 'm ' + pad(s) + 's';
  }
  tick();
  setInterval(tick, 1000);
}

function buildDayRows(sortedDays, days) {
  const container = document.getElementById('days-container');
  const todayKey = (() => { const n = toBali(Date.now()); return n.getFullYear()+'-'+pad(n.getMonth()+1)+'-'+pad(n.getDate()); })();

  let html = '';
  sortedDays.forEach(dayKey => {
    const checks = days[dayKey];
    const isToday = dayKey === todayKey;

    // Day label
    const parts = dayKey.split('-');
    const dateObj = new Date(parts[0], parts[1]-1, parts[2]);
    const dayLabel = isToday ? 'Today' : dateObj.toLocaleDateString('en', { weekday: 'short', month: 'short', day: 'numeric' });

    // Stats
    const openCount = checks.filter(c => c.s === 1).length;
    const closedCount = checks.filter(c => c.s === 0).length;
    const errorCount = checks.filter(c => c.s === -1).length;
    const validCount = openCount + closedCount;
    const uptimePct = validCount > 0 ? (openCount / validCount * 100).toFixed(0) : '--';
    const openMin = openCount * 5;
    const closedMin = closedCount * 5;
    const openH = Math.floor(openMin/60), openM = openMin%60;
    const openStr = openH > 0 ? openH + 'h ' + openM + 'm' : openM + 'm';

    // Find events (status transitions)
    const events = findEvents(checks);
    const anomalyCount = checks.filter(c => c.a).length;
    const hasIssues = anomalyCount > 0 || events.some(e => e.type === 'unexpected_close');

    // Uptime color
    const pctNum = parseFloat(uptimePct) || 0;
    const noData = validCount === 0;
    const uptimeColor = noData ? 'text-gray-300' : pctNum >= 95 ? 'text-green-600' : pctNum >= 70 ? 'text-yellow-600' : 'text-red-600';
    const uptimeIcon = noData ? '⚪' : pctNum >= 95 ? '✅' : pctNum >= 70 ? '⚠️' : '🔴';
    const bgClass = isToday ? 'bg-blue-50/30' : '';

    html += `<div class="group ${bgClass}">`;
    // Day header row (always visible)
    html += `<div class="flex items-center gap-3 px-4 py-3 cursor-pointer hover:bg-gray-50 transition-colors" onclick="toggleDay('${dayKey}')">`;
    html += `<span class="text-sm ${uptimeColor} w-5 text-center flex-shrink-0">${uptimeIcon}</span>`;
    html += `<span class="text-sm ${isToday ? 'font-bold text-gray-900' : 'font-medium text-gray-700'} w-28 flex-shrink-0">${dayLabel}</span>`;
    html += `<span class="text-sm font-semibold ${uptimeColor} w-12 flex-shrink-0">${uptimePct}%</span>`;
    html += `<span class="text-xs text-gray-400 flex-1">${noData ? 'no data' : openStr + ' open'}</span>`;

    if (hasIssues) {
      const issueCount = events.filter(e => e.type === 'unexpected_close').length;
      html += `<span class="text-xs font-medium text-red-500">${issueCount} issue${issueCount !== 1 ? 's' : ''}</span>`;
    }
    html += `<i data-lucide="chevron-right" class="w-4 h-4 text-gray-300 flex-shrink-0 transition-transform" id="chevron-${dayKey}"></i>`;

    html += '</div>';

    // Expandable event log (hidden by default)
    if (events.length > 0) {
      html += `<div id="day-${dayKey}" class="hidden border-t bg-gray-50/50 px-4 py-3">`;
      html += '<div class="space-y-1.5 ml-8">';
      events.forEach(ev => {
        const time = ev.time ? fmtTime(ev.time) : '';
        if (ev.type === 'opened') {
          html += `<div class="flex items-center gap-2 text-sm">`;
          html += `<span class="w-1.5 h-1.5 rounded-full bg-green-500 flex-shrink-0"></span>`;
          html += `<span class="text-gray-500 font-mono w-12">${time}</span>`;
          html += `<span class="text-green-700">Opened</span>`;
          if (ev.downtime) html += `<span class="text-xs text-gray-400 ml-1">(${ev.downtime} downtime)</span>`;
          html += '</div>';
        } else if (ev.type === 'closed') {
          html += `<div class="flex items-center gap-2 text-sm">`;
          html += `<span class="w-1.5 h-1.5 rounded-full bg-gray-400 flex-shrink-0"></span>`;
          html += `<span class="text-gray-500 font-mono w-12">${time}</span>`;
          html += `<span class="text-gray-600">Closed</span>`;
          html += `<span class="text-xs text-gray-300 ml-1">scheduled</span>`;
          html += '</div>';
        } else if (ev.type === 'unexpected_close') {
          html += `<div class="flex items-center gap-2 text-sm">`;
          html += `<span class="w-1.5 h-1.5 rounded-full bg-red-500 flex-shrink-0"></span>`;
          html += `<span class="text-gray-500 font-mono w-12">${time}</span>`;
          html += `<span class="text-red-600 font-medium">Closed unexpectedly</span>`;
          html += `<span class="text-xs bg-yellow-100 text-yellow-700 px-1.5 py-0.5 rounded font-medium ml-1">ANOMALY</span>`;
          html += '</div>';
        } else if (ev.type === 'monitoring') {
          const durM = ev.mins || 0;
          const dH = Math.floor(durM/60), dM = durM%60;
          const durStr = dH > 0 ? dH + 'h ' + dM + 'm' : dM + 'm';
          const statusLabel = ev.status === 'open' ? 'open' : ev.status === 'closed' ? 'closed' : 'monitoring';
          const dotColor = ev.status === 'open' ? 'bg-green-200' : ev.status === 'closed' ? 'bg-red-200' : 'bg-gray-200';
          html += `<div class="flex items-center gap-2 text-xs text-gray-300 py-0.5 ml-3">`;
          html += `<span class="border-l border-dashed ${dotColor} h-4"></span>`;
          html += `<span>✓ ${ev.count} checks OK · ${durStr} ${statusLabel}</span>`;
          html += '</div>';
        }
      });
      html += '</div></div>';
    }

    html += '</div>';
  });

  container.innerHTML = html || '<div class="p-8 text-center text-sm text-gray-300">No data for this period</div>';
  lucide.createIcons();
}

function findEvents(checks) {
  if (!checks.length) return [];
  const events = [];

  // Filter out errors: treat them as continuation of last known status
  const realChecks = [];
  checks.forEach(c => {
    if (c.s !== -1) realChecks.push(c); // skip errors
  });

  // Also count total checks (including errors) between events for "monitoring" lines
  const allChecks = checks;

  if (!realChecks.length) {
    // All errors - show summary
    if (allChecks.length > 0) {
      events.push({ type: 'monitoring', count: allChecks.length, status: 'error',
        startTime: allChecks[0].bali, endTime: allChecks[allChecks.length-1].bali });
    }
    return events;
  }

  let prevStatus = null;
  let lastCloseTime = null;
  let lastEventTime = null;
  let checksSinceLastEvent = 0;

  realChecks.forEach((c, i) => {
    const status = c.s; // 1=open, 0=closed
    const time = c.bali;

    if (prevStatus === null) {
      // First real check
      if (status === 1) events.push({ type: 'opened', time });
      else events.push({ type: 'closed', time });
      lastEventTime = time;
      checksSinceLastEvent = 0;
    } else if (status !== prevStatus) {
      // Status transition - add monitoring summary before it
      if (checksSinceLastEvent > 1 && lastEventTime) {
        const mins = Math.round((time - lastEventTime) / 60000);
        events.push({ type: 'monitoring', count: checksSinceLastEvent,
          status: prevStatus === 1 ? 'open' : 'closed',
          startTime: lastEventTime, endTime: time, mins });
      }

      if (status === 1 && prevStatus === 0) {
        let downtime = '';
        if (lastCloseTime) {
          const mins = Math.round((time - lastCloseTime) / 60000);
          const h = Math.floor(mins/60), m = mins%60;
          downtime = h > 0 ? h + 'h ' + m + 'm' : m + 'm';
        }
        events.push({ type: 'opened', time, downtime });
        lastCloseTime = null;
      } else if (status === 0 && prevStatus === 1) {
        const isAnomaly = c.a === 1;
        events.push({ type: isAnomaly ? 'unexpected_close' : 'closed', time });
        lastCloseTime = time;
      }
      lastEventTime = time;
      checksSinceLastEvent = 0;
    } else {
      checksSinceLastEvent++;
    }
    prevStatus = status;
  });

  // Add trailing monitoring summary (from last event to end of data)
  if (checksSinceLastEvent > 1 && lastEventTime && realChecks.length > 0) {
    const lastCheck = realChecks[realChecks.length - 1];
    const mins = Math.round((lastCheck.bali - lastEventTime) / 60000);
    events.push({ type: 'monitoring', count: checksSinceLastEvent,
      status: prevStatus === 1 ? 'open' : 'closed',
      startTime: lastEventTime, endTime: lastCheck.bali, mins });
  }

  return events;
}

function toggleDay(dayKey) {
  const el = document.getElementById('day-' + dayKey);
  const chevron = document.getElementById('chevron-' + dayKey);
  if (!el) return;
  el.classList.toggle('hidden');
  if (chevron) {
    chevron.style.transform = el.classList.contains('hidden') ? '' : 'rotate(90deg)';
  }
}

async function loadMenuSummary() {
  const el = document.getElementById('menu-summary');
  try {
    const resp = await fetch(`/restaurants/${RID}.json`);
    if (!resp.ok) { el.textContent = ''; return; }
    const data = await resp.json();
    const items = data.menu_items || [];
    if (!items.length) { el.textContent = ''; return; }
    const oos = items.filter(i => i.current_status === 0);
    if (oos.length === 0) {
      el.innerHTML = '<span class="text-green-600">Menu: all ' + items.length + ' items available</span>';
    } else {
      el.innerHTML = '<span class="text-red-600">Menu: ' + oos.length + ' of ' + items.length + ' items out of stock</span>';
    }
  } catch(e) { el.textContent = ''; }
}

loadData();
</script>
</body>
</html>
